---
/**
 * index.astro
 * ─────────────────────────────────────────────────────────────────
 * Main portfolio page driven by index_content.md.
 * Route: /
 * ─────────────────────────────────────────────────────────────────
 */
import MainCanvas from '../components/figma-page/MainCanvas.astro';
import SandboxBlock from '../components/figma-page/Test-Block.astro';
import ProjOverlay from '../components/figma-page/proj_overlay.astro';
import '../styles/global.css';

import { getEntry } from 'astro:content';
const sandboxEntry = await getEntry('pages', 'index_content');
const sections = sandboxEntry?.data.sections || [];

const highlightedSection = sections.find((section: any) => section.component === 'HighlightedProjectsSection');
const highlightedProjects = Array.isArray(highlightedSection?.props?.projectList)
  ? highlightedSection.props.projectList
  : [];

const overlayProjectSlugs = highlightedProjects
  .map((project: any) => (typeof project?.projectSlug === 'string' ? project.projectSlug.trim() : ''))
  .filter((slug: string, index: number, slugs: string[]) => slug.length > 0 && slugs.indexOf(slug) === index);

const validOverlayComponents = new Set([
  'ProjTextCardLeft',
  'ProjTextCardRight',
  'ProjTextCardWideImage',
]);

const overlayProjects = (
  await Promise.all(
    overlayProjectSlugs.map(async (projectSlug: string) => {
      const overlayProjectEntry = await getEntry('projects', projectSlug);
      if (!overlayProjectEntry) return null;

      const sectionsData = overlayProjectEntry.data.sections ?? [];
      const overlayBlocks = sectionsData
        .filter((section: any) =>
          section &&
          typeof section === 'object' &&
          'component' in section &&
          typeof section.component === 'string' &&
          validOverlayComponents.has(section.component)
        )
        .map((section: any) => ({
          component: section.component,
          props: section.props ?? {},
        }));

      if (overlayBlocks.length === 0) return null;

      return {
        projectSlug,
        overlayBlocks,
      };
    })
  )
).filter(
  (project): project is { projectSlug: string; overlayBlocks: Array<{ component: string; props: Record<string, any> }> } =>
    Boolean(project)
);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Gonçalo Mendonça - Portfolio</title>

    <!-- Fonts: same stack as production -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Space+Mono:wght@400;700&family=Plus+Jakarta+Sans:wght@300;400;500;600;700&display=swap"
      rel="stylesheet"
    />
  </head>

  <body class="bg-white font-body text-black">

    <!-- Grid background — fixed behind all content, aria-hidden so screen readers skip it -->
    <div class="sandbox-grid-bg" aria-hidden="true"></div>

    <MainCanvas>
      {sections.map((block: any) => (
        <SandboxBlock block={block} />
      ))}
    </MainCanvas>

    {overlayProjects.map((project) => (
      <ProjOverlay
        projectSlug={project.projectSlug}
        overlayBlocks={project.overlayBlocks}
      />
    ))}

  </body>
</html>
