---
import Base from "../layouts/Base.astro";
import { site } from "../content/site";
import Filter from "../components/Filter.astro";
import ProjectGrid from "../components/ProjectGrid.astro";
import FeatureBlock from "../components/FeatureBlock.astro";

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  name: site.name,
  url: site.url,
  inLanguage: site.locale,
};
---

<Base
  title={site.name}
  description={site.description}
  canonicalPath="/"
  jsonLd={jsonLd}
>
  <article class="prose">
    <!-- Main section heading — demoted to H2 because the hero contains the H1 -->
    <h2 class="prose__title">{site.tagline}</h2>
    <p class="lead">{site.description}</p>
  </article>

  <section id="projects" class="block">
    <h2>Projetos Tecit</h2>
    <Filter />

    <h3>Featured</h3>
    <ProjectGrid include={["project-one","project-two","project-three","project-four","project-five","project-six"]} />

    <h3>Pessoais</h3>
    <ProjectGrid include={["project-seven","project-eight","project-nine"]} />

    <h3>Projetos Velhos</h3>
    <ProjectGrid include={["project-ten"]} />
  </section>

  <!-- Feature blocks following the project grid; content-driven from site.features -->
  {site.features?.map(feature => (
    <FeatureBlock title={feature.title} text={feature.text} image={feature.image} reverse={feature.reverse} />
  ))}

  <section id="about" class="block" aria-labelledby="about-title">
    <h2 id="about-title">About</h2>
    <article class="prose">
      <p class="lead">
        {site.name} is a minimal Porta focused on structure, clarity, and
        build-time decisions.
      </p>

      <p>
        This starter intentionally avoids UI kits, heavy abstractions, and runtime
        JavaScript. It provides a solid foundation for websites that value
        performance, accessibility, and long-term maintainability.
      </p>

      <p>
        You are expected to adapt it, extend it, and make it your own.
      </p>
    </article>
  </section>

  <section id="contact" class="block" aria-labelledby="contact-title">
    <h2 id="contact-title">Contact</h2>
    <article class="prose">
      <p class="lead">This site does not include a contact form by default.</p>

      <p>
        If you need to get in touch, you can reach us by email:
      </p>

      {site.author.email && (
        <p>
          <a href={`mailto:${site.author.email}`}>
            {site.author.email}
          </a>
        </p>
      )}

      <p>
        This keeps the baseline simple and avoids unnecessary JavaScript.
      </p>
    </article>
  </section>

  <section id="legal" class="block" aria-labelledby="legal-title">
    <h2 id="legal-title">Legal</h2>
    <article class="prose">
      <p>
        This website is provided as-is, without any guarantee or warranty.
      </p>

      <p>
        Content published on this site may be modified or removed at any time.
      </p>

      <p>
        If you have any legal concerns, please contact the site owner.
      </p>

      {site.author.email && (
        <p>
          Contact: <a href={`mailto:${site.author.email}`}>{site.author.email}</a>
        </p>
      )}
    </article>
  </section>
</Base>
