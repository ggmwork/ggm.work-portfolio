---
/**
 * figma-sandbox.astro
 * ─────────────────────────────────────────────────────────────────
 * Standalone design sandbox page.
 * No Base.astro / Header / Footer — purely for visual component review.
 * Route: /figma-sandbox
 * ─────────────────────────────────────────────────────────────────
 */
import MainCanvas from "../components/cards/base/MainCanvas.astro";
import SandboxBlock from "../components/cards/pipeline/SandboxBlock.astro";
import "../styles/global.css";

import { getEntry } from "astro:content";
const sandboxEntry = await getEntry("pages", "figma-sandbox");
const sections = sandboxEntry?.data.sections || [];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Figma Sandbox — Component Preview</title>

    <!-- Instruct crawlers to skip this dev-only page -->
    <meta name="robots" content="noindex, nofollow" />

    <!-- Fonts: non-blocking async load -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Space+Mono:wght@400;700&family=Plus+Jakarta+Sans:wght@300;400;500;600;700&display=swap"
      rel="stylesheet"
      media="print"
      onload="this.media='all'"
    />
    <noscript>
      <link
        href="https://fonts.googleapis.com/css2?family=Space+Mono:wght@400;700&family=Plus+Jakarta+Sans:wght@300;400;500;600;700&display=swap"
        rel="stylesheet"
      />
    </noscript>
  </head>

  <body class="bg-white font-body text-black">
    <MainCanvas>
      {sections.map((block: any) => <SandboxBlock block={block} />)}
    </MainCanvas>
  </body>
</html>
