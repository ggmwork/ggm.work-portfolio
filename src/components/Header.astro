---
import { site } from '../content/site';
---

<!--
  Header (minimal prototype)
  - Uses Tailwind utilities for layout/spacing
  - Reads site name/tagline from `src/content/site.ts` (content source of truth)
  - Minimal decorative SVG for the sketchy lines in the mock
  - Buttons are links (navigation) styled as controls for accessibility
-->
<!--
  Hero header (prototype)
  - Content-driven headings come from `src/content/site.ts` (single source of truth)
  - Background image uses `site.seo.ogImage` as a simple hero placeholder
  - Accessible: background marked `aria-hidden`, semantic H1/H2 used, actions are anchors for navigation
-->
<header class="hero" role="banner" aria-label="Site header">
  <!-- Decorative background; kept separate from content for accessibility -->
  <div class="hero__bg" aria-hidden="true" style={`background-image: linear-gradient(rgba(0,0,0,0.45), rgba(0,0,0,0.25)), url(${site.seo.ogImage})`} />

  <div class="hero__content">
    <!-- Primary heading (site name) -->
    <h1 class="hero__title">{site.name}</h1>

    <!-- Secondary heading / tagline -->
    <h2 class="hero__subtitle">{site.tagline}</h2>

    <!-- Actions (anchors used for navigation; visible, keyboard-accessible) -->
    <div class="hero__actions" role="group" aria-label="Primary actions">
      <a href="/files/PDF_TestPage.pdf" class="btn hero__btn" download target="_blank" rel="noopener">Download CV</a>
      <a href={`mailto:${site.author.email}`} class="btn hero__btn btn--ghost">Send a Email</a>
      <a href="/#projects" class="btn hero__btn btn--ghost">Check my project’s</a>
    </div>
  </div>
</header>
