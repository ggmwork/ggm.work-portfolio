---
/**
 * ButtonSecondary.astro
 * ─────────────────────────────────────────────────────────────────
 * ATOM — Secondary action button.
 *
 * Visual spec (Figma):
 *   Fill    → bg-white  (#FDFDF9 via --color-white)
 *   Stroke  → ring-1 ring-grey  (1px outside, #E6E7F2)
 *   Radius  → rounded-[8px]  (Figma spec: 8px corner radius)
 *   Text    → Plus Jakarta Sans Semibold 16px — font-body font-semibold text-base text-black
 *   Effects → btn-effects (scaled inner + drop shadow) + btn-blur (0.5px)
 *
 * Arbitrary value justification:
 *   [8px]  Figma frame radius spec.
 * ─────────────────────────────────────────────────────────────────
 */
interface Props {
  label?: string;
  href?: string;
}
const { label = 'Button', href } = Astro.props;
---

{href ? (
  <a
    href={href}
    class="btn-effects btn-blur inline-flex items-center justify-center bg-white ring-1 ring-grey rounded-[8px] px-6 py-3 font-body font-semibold text-base text-black"
  >
    {label}
  </a>
) : (
  <button
    type="button"
    class="btn-effects btn-blur inline-flex items-center justify-center bg-white ring-1 ring-grey rounded-[8px] px-6 py-3 font-body font-semibold text-base text-black"
  >
    {label}
  </button>
)}
