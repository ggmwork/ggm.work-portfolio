---
/**
 * ButtonSecondary.astro
 * ─────────────────────────────────────────────────────────────────
 * ATOM  Secondary action button.
 *
 * Visual spec (Figma):
 *   Fill    → bg-white  (#FDFDF9 via --color-white)
 *   Stroke  → ring-1 ring-grey  (1px outside, #E6E7F2)
 *   Radius  → rounded-[8px]  (Figma spec: 8px corner radius)
 *   Text    → Plus Jakarta Sans Semibold 16px  font-body font-semibold text-base text-black
 *   Effects → btn-effects (scaled inner + drop shadow) + btn-blur (no-op)
 *
 * States:
 *   Default  → bg-white, btn-effects shadow depth
 *   Hover    → lift -2px, shadow-lg, bg-grey/30 tint
 *   Active   → press down scale(0.97), translate-y-px, shadow-sm
 *   Focus    → 2px brand ring with 2px offset (accessibility)
 *
 * Arbitrary value justifications:
 *   [8px]   Figma frame radius spec.
 *   [0.97]  Slightly more pronounced than 0.98 for tactile click feedback.
 * ─────────────────────────────────────────────────────────────────
 */
interface Props {
  label?: string;
  href?: string;
}
const { label = "Button", href } = Astro.props;

const btnClasses = [
  /* Base */
  "btn-effects btn-blur inline-flex items-center justify-center",
  "bg-white ring-1 ring-grey rounded-[8px] px-6 py-3",
  "font-body font-semibold text-base text-black",
  /* Transition */
  "transition-all duration-200 ease-out",
  /* Hover */
  "hover:-translate-y-0.5 hover:shadow-lg hover:bg-grey/30",
  /* Active / Click */
  "active:scale-[0.97] active:translate-y-px active:shadow-sm",
  /* Focus-visible (accessibility) */
  "focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand focus-visible:ring-offset-2",
].join(" ");
---

{
  href ? (
    <a href={href} class={btnClasses}>
      {label}
    </a>
  ) : (
    <button type="button" class={btnClasses}>
      {label}
    </button>
  )
}
