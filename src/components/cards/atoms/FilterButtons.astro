---
/**
 * FilterButtons.astro
 * ─────────────────────────────────────────────────────────────────
 * MOLECULE — Horizontal filter button strip.
 *
 * Visual spec (Figma):
 *   Container → bg-white rounded-[8px] ring-1 ring-grey
 *               Corners align with the outer edge of first/last button.
 *
 *   Button (default) → bg-white ring-1 ring-grey rounded-[8px]
 *                      font-body font-semibold text-sm text-black
 *                      px-4 py-2  (slightly narrower than ButtonSecondary)
 *                      btn-effects btn-blur
 *
 *   Button (active)  → bg-grey text-brand  (same ring & radius)
 *
 *   Separator → w-1.5 h-1.5 rounded-full bg-brand-light
 *               Rendered between every pair of buttons.
 *
 * Props:
 *   filters  — array of label strings
 *   active   — index of the currently active button (default 0)
 *
 * Arbitrary value justifications:
 *   [8px]  Figma border-radius spec for container and buttons
 * ─────────────────────────────────────────────────────────────────
 */
interface Props {
  filters?: string[];
  active?: number;
}

const {
  filters = ["Design", "UX/UI", "3D", "Motion", "Design", "Design"],
  active = 0,
} = Astro.props;
---

<div class="relative inline-flex">
  <!--
    White container — sits behind all buttons.
    absolute inset-0 so it stretches exactly to the outer button edges.
    rounded-[8px] matches button radius so corners appear flush.
  -->
  <div
    class="absolute inset-0 bg-white rounded-[8px] ring-1 ring-grey"
    aria-hidden="true"
  >
  </div>

  <!--
    Button row with brand-light dot separators.
    p-1 gives a tight margin between the container edge and buttons.
    gap-2 adds consistent spacing between each button+dot pair.
  -->
  <div
    class="relative z-10 inline-flex flex-wrap items-center gap-2"
    role="group"
    aria-label="Filter buttons"
  >
    {
      filters.map((filter, i) => (
        <Fragment>
          {/* Dot separator — rendered before every button except the first */}
          {i > 0 && (
            <span
              class="w-1.5 h-1.5 rounded-full bg-brand-light shrink-0"
              aria-hidden="true"
            />
          )}

          <button
            type="button"
            class:list={[
              /* Base — same effects as ButtonSecondary, slightly smaller padding */
              "btn-effects btn-blur inline-flex items-center justify-center",
              "rounded-[8px] px-4 py-2.5 ring-1 ring-grey",
              "font-body font-semibold text-sm whitespace-nowrap",
              /* State */
              i === active
                ? "bg-grey text-brand" /* Active: grey bg + brand purple text */
                : "bg-white text-black" /* Default: white bg + black text       */,
            ]}
            aria-pressed={i === active ? "true" : "false"}
          >
            {filter}
          </button>
        </Fragment>
      ))
    }
  </div>
</div>
