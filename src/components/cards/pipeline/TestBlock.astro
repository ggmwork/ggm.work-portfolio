---
/**
 * Dynamic block resolver designed to render the correct HTML wrapper and
 * inner components for the index page based on Markdown sections.
 */
import HeaderCard from "../cards/HeaderCard.astro";
import AboutMeCard from "../cards/AboutMeCard.astro";
import AboutImageBlock from "../cards/AboutImageBlock.astro";
import HighlightedProjCard from "../cards/HighlightedProjCard.astro";
import MoreProjectsCard from "../cards/MoreProjectsCard.astro";
import WorkExpCard from "../cards/WorkExpCard.astro";
import AllSkillsCard from "../cards/AllSkillsCard.astro";
import EduLangCard from "../cards/EduLangCard.astro";
import CTATextCard from "../cards/CTATextCard.astro";
import ContactCard from "../cards/ContactCard.astro";
import BaseCard from "../base/BaseCard.astro";
import HeroCard from "../cards/HeroCard.astro";
import FilterButtons from "../atoms/FilterButtons.astro";
import TextBlock from "../atoms/TextBlock.astro";
import TextBlockVariant2 from "../atoms/TextBlockVariant2.astro";
import ButtonPrimary from "../atoms/ButtonPrimary.astro";
import ButtonSecondary from "../atoms/ButtonSecondary.astro";
import Label from "../atoms/Label.astro";
import ImageBlock from "../cards/ImageBlock.astro";

const { block } = Astro.props;
const { component, props = {} } = block;
---

{
  component === "HeaderSection" && (
    <section class="pt-32" aria-label="ORGANISM: Header Card">
      <h1 class="font-heading font-bold text-5xl md:text-6xl text-black mb-6 pl-6 md:pl-32 leading-tight tracking-tight">
        {props.heading}
      </h1>
      <HeaderCard {...props.cardProps} />
    </section>
  )
}

{
  component === "AboutSection" && (
    <section
      class="pt-24 flex flex-col md:flex-row gap-8 items-start justify-between w-full"
      aria-label="ORGANISM: About Me Card"
    >
      <div class="w-full">
        <h2 class="font-heading font-bold text-4xl text-black mb-6 pl-6 md:pl-32 leading-tight tracking-tight">
          {props.heading}
        </h2>
        <AboutMeCard {...props.cardProps} />
      </div>
      <div class="flex items-center justify-end mt-22">
        <AboutImageBlock {...props.imageBlockProps} />
      </div>
    </section>
  )
}

{
  component === "HighlightedProjectsSection" && (
    <section
      id="highlighted-projects"
      class="pt-24 pb-20 w-full flex flex-col gap-16"
      aria-label="ORGANISM: Highlighted Projects"
    >
      <h2 class="font-heading font-bold text-4xl text-black pl-6 md:pl-32 leading-tight tracking-tight">
        {props.heading}
      </h2>
      {props.projectList &&
        props.projectList.map((project: any) => (
          <HighlightedProjCard {...project} />
        ))}
    </section>
  )
}

{
  component === "MoreProjectsSection" && (
    <section class="pt-24 pb-20 w-full" aria-label="ORGANISM: More Projects">
      <h2 class="font-heading font-bold text-4xl text-black mb-6 pl-8 md:pl-32 leading-tight tracking-tight">
        {props.heading}
      </h2>
      <MoreProjectsCard {...props.cardProps} />
    </section>
  )
}

{
  component === "WorkSkillsSection" && (
    <section
      class="pt-24 pb-20 w-full flex flex-col xl:flex-row gap-8 items-start justify-between"
      aria-label="ORGANISM: Work Experience & All Skills"
    >
      <div class="w-full xl:w-[68%]">
        <h2 class="font-heading font-bold text-4xl text-black mb-6 pl-8 md:pl-32 leading-tight tracking-tight">
          {props.workHeading}
        </h2>
        <div class="[&>article]:w-full [&>article]:md:w-full">
          <WorkExpCard {...props.workProps} />
        </div>
      </div>
      <div class="w-full xl:w-[30%] flex flex-col justify-start mt-22">
        <!-- Kept original pl-12 for skills heading since the card itself is flush-right -->
        <h2 class="font-heading font-bold text-4xl text-black mb-6 pl-8 md:pl-16 leading-tight tracking-tight">
          {props.skillsHeading}
        </h2>
        <AllSkillsCard {...props.skillsProps} />
      </div>
    </section>
  )
}

{
  component === "EducationLangSection" && (
    <section
      class="pt-12 pb-20 w-full"
      aria-label="ORGANISM: Education and Languages"
    >
      <h2 class="font-heading font-bold text-4xl text-black mb-6 pl-8 md:pl-36 leading-tight tracking-tight">
        {props.heading}
      </h2>
      <EduLangCard {...props.cardProps} />
    </section>
  )
}

{
  component === "CTASection" && (
    <section class="pt-8 pb-12 w-full" aria-label="ORGANISM: CTA Text">
      <CTATextCard {...props.cardProps} />
    </section>
  )
}

{
  component === "ContactSection" && (
    <section
      id="contact"
      class="pt-12 pb-20 w-full"
      aria-label="ORGANISM: Contact"
    >
      <h2 class="font-heading font-bold text-4xl text-black mb-6 pl-[37vw] leading-tight tracking-tight">
        {props.heading}
      </h2>
      <ContactCard {...props.cardProps} />
    </section>
  )
}
