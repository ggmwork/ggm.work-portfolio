---
/**
 * BaseCard.astro
 * ─────────────────────────────────────────────────────────────────
 * The single source of truth for the card shell.
 *
 * Owns the visual DNA that every card shares:
 *   bg-white · ring-[5px] ring-grey · base-card-shadow ·
 *   base-card-blur · base-card-grid · rounded corners ·
 *   stacking context (relative + inner z-10 wrapper)
 *
 * Each instance controls its own dimensions by passing Tailwind
 * classes via the `class` prop  e.g. max-w-[1100px] md:w-[63%].
 *
 * Props:
 *   align     → "left" (flush-left, rounded-right) or
 *               "right" (flush-right, rounded-left)
 *   class     → extra classes merged onto <article> (sizing, flex, etc.)
 *   ariaLabel → accessibility label
 *
 * Arbitrary value justifications:
 *   [5px]          Card ring spec (Figma stroke width)
 *   [2rem]/[2.5rem] Card corner radius (Figma spec)
 * ─────────────────────────────────────────────────────────────────
 */
interface Props {
  align?: "left" | "right" | "full";
  class?: string;
  ariaLabel?: string;
}

const {
  align = "left",
  class: extraClass = "",
  ariaLabel = "Content card",
} = Astro.props;

const isRight = align === "right";
const isFull = align === "full";

/* ── Rounding ── */
const roundingClasses = isFull
  ? "rounded-none"
  : isRight
    ? "rounded-l-[2rem] md:rounded-l-[2.5rem] rounded-r-none"
    : "rounded-r-[2rem] md:rounded-r-[2.5rem] rounded-l-none";

/* ── Positioning ── */
const positionClass = isFull ? "" : isRight ? "ml-auto" : "";

/* ── Assemble ── */
const shellClasses = [
  positionClass,
  "bg-white ring-[5px] ring-grey",
  roundingClasses,
  "w-full",
  "base-card-shadow base-card-blur base-card-grid relative",
  extraClass,
]
  .filter(Boolean)
  .join(" ");
---

<article class={shellClasses} aria-label={ariaLabel}>
  <!-- Content layer  above the base-card-grid ::before (z-0) -->
  <div class="relative z-10 h-full">
    <slot />
  </div>
</article>
