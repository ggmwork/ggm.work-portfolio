---
/**
 * Proj_Text_Card.astro
 * Overlay text card variants driven by markdown.
 *
 * Arbitrary class justifications (same values used in existing Figma-sandbox cards):
 * - rounded-[40px]: image radius value
 * - min-h-[350px]: About text card minimum height from existing About section
 * - rounded-[19px]: inner frosted panel radius from existing text blocks
 * - blur-[20px]: frosted panel blur intensity from existing text blocks
 */
import { Image } from "astro:assets";
import { resolveImage } from "../../../lib/resolve-image";
import { marked } from "marked";
import BaseCard from "../base/BaseCard.astro";
import Label from "../atoms/Label.astro";

interface CardImage {
  src: string;
  alt?: string;
  position?: "above" | "below";
  aspectRatio?: string;
  rounded?: boolean;
  maxWidth?: string;
}

interface Props {
  headingId?: string;
  heading?: string;
  labels?: string[];
  paragraph1?: string;
  paragraph2?: string;
  imageSrc?: string;
  imageAlt?: string;
  wideImageSrc?: string;
  wideImageAlt?: string;
  variant?: "left" | "right" | "wide-image-end";
  isFirstCard?: boolean;
  paddingLeft?: string;
  paddingRight?: string;
  cardImage?: CardImage;
}

const {
  headingId,
  heading = "",
  labels,
  paragraph1 = "",
  paragraph2 = "",
  imageSrc = "/images/headshot.png",
  imageAlt = "About profile image",
  wideImageSrc,
  wideImageAlt,
  variant = "left",
  isFirstCard = false,
  paddingLeft,
  paddingRight,
  cardImage,
} = Astro.props;

const hasLabels = Array.isArray(labels) && labels.length > 0;

const isRight = variant === "right";
const isWideImageEnd = variant === "wide-image-end";
const trailingImageSrc = wideImageSrc ?? imageSrc;
const trailingImageAlt = wideImageAlt ?? imageAlt;
const resolvedTrailingImage = resolveImage(trailingImageSrc);
const hasHeading = !isRight && heading.trim().length > 0;
const hasParagraph1 = paragraph1.trim().length > 0;
const hasParagraph2 = paragraph2.trim().length > 0;
const paragraph1Html = hasParagraph1
  ? await marked.parseInline(paragraph1)
  : "";
const paragraph2Html = hasParagraph2
  ? await marked.parseInline(paragraph2)
  : "";

const textCardAlign: "left" | "right" = isRight ? "right" : "left";

/* ── Per-card padding: markdown overrides fall back to defaults ── */
const defaultPl = isRight ? "md:pl-10" : "md:pl-15";
const defaultPr = isRight ? "md:pr-15" : "md:pr-10";
const effectivePl = paddingLeft ?? defaultPl;
const effectivePr = paddingRight ?? defaultPr;

const textCardContentClass = `p-6 ${effectivePl} md:py-10 ${effectivePr} flex-1 flex flex-col gap-5`;

/* ── Section top padding: first card gets slight top padding, others none ── */
const sectionPadding = isFirstCard
  ? "pt-4 md:pt-6"
  : "";

/* ── In-card image ── */
const hasCardImage = cardImage && cardImage.src;
const resolvedCardImage = hasCardImage ? resolveImage(cardImage.src) : undefined;
const cardImageAlt = cardImage?.alt ?? "";
const cardImagePosition = cardImage?.position ?? "below";
const cardImageRounded = cardImage?.rounded !== false;
const cardImageMaxWidth = cardImage?.maxWidth ?? "100%";
const cardImageAspectRatio = cardImage?.aspectRatio ?? "auto";
const cardImageRoundedClass = cardImageRounded ? "rounded-[19px]" : "";
const cardImageStyle = cardImageAspectRatio !== "auto"
  ? `aspect-ratio: ${cardImageAspectRatio}; max-width: ${cardImageMaxWidth};`
  : `max-width: ${cardImageMaxWidth};`;
---

<section
  class={`${sectionPadding} flex flex-col gap-4 md:gap-8 w-full`}
  aria-label="Project overlay text card section"
>
  <div class="w-full">
    {
      hasHeading && (
        <h2
          id={headingId}
          class="font-heading font-bold text-2xl md:text-4xl text-black mb-6 pl-4 md:pl-15 leading-tight tracking-tight"
        >
          {heading}
        </h2>
      )
    }

    <BaseCard
      align={textCardAlign}
      class="max-w-[1100px] md:w-[63%] min-h-[350px] overflow-hidden flex flex-col justify-center"
      ariaLabel="Overlay text card"
    >
      <div class={textCardContentClass}>
        <div class="relative">
          <div
            class="absolute inset-0 rounded-[19px] bg-white/60 backdrop-blur-[20px]"
            aria-hidden="true"
          >
          </div>
          <div class="relative z-10 px-5 py-4 flex flex-col gap-4">
            {
              hasCardImage && cardImagePosition === "above" && (
                <div class="w-full">
                  {resolvedCardImage ? (
                    <Image
                      src={resolvedCardImage}
                      alt={cardImageAlt}
                      width={1100}
                      height={619}
                      class={`img-drop-shadow w-full object-contain block ring-2 ring-grey ${cardImageRoundedClass}`}
                      style={cardImageStyle}
                      loading="lazy"
                      decoding="async"
                    />
                  ) : (
                    <img
                      src={cardImage!.src}
                      alt={cardImageAlt}
                      width="1100"
                      height="619"
                      class={`img-drop-shadow w-full object-contain block ring-2 ring-grey ${cardImageRoundedClass}`}
                      style={cardImageStyle}
                      loading="lazy"
                      decoding="async"
                    />
                  )}
                </div>
              )
            }
            {
              hasLabels && (
                <div class="flex flex-wrap gap-2">
                  {labels!.map((lbl: string) => (
                    <Label label={lbl} />
                  ))}
                </div>
              )
            }
            {
              !hasLabels && hasParagraph1 && (
                <p
                  class="font-body font-medium text-base md:text-lg text-black leading-relaxed"
                  set:html={paragraph1Html}
                />
              )
            }
            {
              hasParagraph2 && (
                <p
                  class="font-body font-medium text-base md:text-lg text-black leading-relaxed"
                  set:html={paragraph2Html}
                />
              )
            }
            {
              hasCardImage && cardImagePosition === "below" && (
                <div class="w-full">
                  {resolvedCardImage ? (
                    <Image
                      src={resolvedCardImage}
                      alt={cardImageAlt}
                      width={1100}
                      height={619}
                      class={`img-drop-shadow w-full object-contain block ring-2 ring-grey ${cardImageRoundedClass}`}
                      style={cardImageStyle}
                      loading="lazy"
                      decoding="async"
                    />
                  ) : (
                    <img
                      src={cardImage!.src}
                      alt={cardImageAlt}
                      width="1100"
                      height="619"
                      class={`img-drop-shadow w-full object-contain block ring-2 ring-grey ${cardImageRoundedClass}`}
                      style={cardImageStyle}
                      loading="lazy"
                      decoding="async"
                    />
                  )}
                </div>
              )
            }
          </div>
        </div>
      </div>
    </BaseCard>
  </div>

  {
    isWideImageEnd && (
      <BaseCard
        class="max-w-[1100px] md:w-[63%] overflow-hidden"
        ariaLabel="Overlay trailing 16:9 image block"
      >
        <div class="p-4 md:p-6">
          {resolvedTrailingImage ? (
            <Image
              src={resolvedTrailingImage}
              alt={trailingImageAlt}
              width={1100}
              height={619}
              class="img-drop-shadow w-full aspect-video rounded-[40px] object-cover block ring-2 ring-grey"
              loading="lazy"
              decoding="async"
            />
          ) : (
            <img
              src={trailingImageSrc}
              alt={trailingImageAlt}
              width="1100"
              height="619"
              class="img-drop-shadow w-full aspect-video rounded-[40px] object-cover block ring-2 ring-grey"
              loading="lazy"
              decoding="async"
            />
          )}
        </div>
      </BaseCard>
    )
  }
</section>
