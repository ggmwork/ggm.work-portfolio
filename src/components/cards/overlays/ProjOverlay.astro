---
/**
 * proj_overlay.astro
 * About-only project overlay for the homepage.
 */
import ProjTextCard from "./ProjTextCard.astro";

interface OverlayBlockData {
  component: string;
  props?: Record<string, any>;
}

interface Props {
  projectSlug?: string;
  overlayBlocks?: OverlayBlockData[];
}

const { projectSlug = "", overlayBlocks = [] } = Astro.props;

const normalizedProjectSlug =
  typeof projectSlug === "string" ? projectSlug.trim() : "";
const overlayId = normalizedProjectSlug
  ? `project-overlay-${normalizedProjectSlug}`
  : "project-overlay";

const variantByComponent: Record<string, "full" | "left" | "right" | "wide-image-end"> =
  {
    ProjTextCard: "full",
    ProjTextCardLeft: "left",
    ProjTextCardRight: "right",
    ProjTextCardWideImage: "wide-image-end",
  };

const resolvedOverlayBlocks = overlayBlocks
  .map((block) => {
    const variant = variantByComponent[block.component];
    if (!variant) return null;

    return {
      variant,
      props: block.props ?? {},
    };
  })
  .filter(
    (
      block,
    ): block is {
      variant: "full" | "left" | "right" | "wide-image-end";
      props: Record<string, any>;
    } => Boolean(block),
  );
---

{
  resolvedOverlayBlocks.length > 0 && (
    <div
      id={overlayId}
      data-project-overlay
      data-project-overlay-slug={normalizedProjectSlug}
      class="fixed inset-0 z-50 hidden overflow-y-auto"
      role="dialog"
      aria-modal="true"
      aria-label="Project overlay"
      aria-hidden="true"
      tabindex="-1"
    >
      <button
        type="button"
        class="fixed inset-0 bg-black/45"
        data-project-overlay-close
        aria-label="Close project overlay"
      />

      <div class="relative z-10 pb-16">
        {/* SVG noise filter for the overlay canvas */}
        <svg
          width="0"
          height="0"
          class="absolute overflow-hidden"
          aria-hidden="true"
          focusable="false"
        >
          <defs>
            <filter
              id={`overlay-noise-filter-${normalizedProjectSlug}`}
              x="0%"
              y="0%"
              width="100%"
              height="100%"
              color-interpolation-filters="sRGB"
            >
              <feTurbulence
                type="fractalNoise"
                baseFrequency="0.65"
                numOctaves="1"
                stitchTiles="stitch"
                result="noiseOut"
              />
              <feColorMatrix
                in="noiseOut"
                type="saturate"
                values="0"
                result="monoNoise"
              />
            </filter>
          </defs>
        </svg>

        {/* Old-style canvas: gutters, rounded corners, border, shadow */}
        <main
          class="mx-canvas-overlay mt-canvas rounded-canvas canvas-gradient border-2 border-grey canvas-shadow canvas-backdrop-blur min-h-canvas relative overflow-hidden"
          aria-label="Project overlay canvas"
        >
          {/* Noise overlay  uses per-overlay filter ID to avoid conflicts */}
          <div
            class="absolute inset-0 pointer-events-none bg-white opacity-30 mix-blend-overlay z-0"
            style={`filter: url(#overlay-noise-filter-${normalizedProjectSlug}); border-radius: inherit; isolation: isolate;`}
            aria-hidden="true"
          />

          <div class="relative z-10">
            <div class="w-full flex justify-end pt-5 px-6 md:px-15">
              <button
                type="button"
                data-project-overlay-close
                data-project-overlay-close-button
                class="btn-effects btn-blur inline-flex items-center justify-center bg-white ring-1 ring-grey rounded-lg px-6 py-3 font-body font-semibold text-base text-black transition-all duration-200 ease-out hover:-translate-y-0.5 hover:shadow-lg hover:bg-grey/30 active:scale-[0.97] active:translate-y-px active:shadow-sm focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand focus-visible:ring-offset-2"
              >
                Close Project
              </button>
            </div>

            <div class="flex flex-col gap-4">
              {resolvedOverlayBlocks.map((block, index) => (
                <ProjTextCard
                  headingId={
                    index === 0 && block.variant !== "right"
                      ? `${overlayId}-title`
                      : undefined
                  }
                  isFirstCard={index === 0}
                  variant={block.variant}
                  {...block.props}
                />
              ))}
            </div>
          </div>
        </main>
      </div>
    </div>
  )
}

<script>
  function initProjectOverlays() {
    const overlays = Array.from(
      document.querySelectorAll("[data-project-overlay]"),
    ).filter((node): node is HTMLElement => node instanceof HTMLElement);
    if (overlays.length === 0) return;

    const overlayBySlug = new Map<string, HTMLElement>();
    overlays.forEach((overlay) => {
      const slug = overlay.getAttribute("data-project-overlay-slug");
      if (slug) {
        overlayBySlug.set(slug, overlay);
      }
    });

    const triggers = Array.from(
      document.querySelectorAll("[data-project-overlay-trigger]"),
    ).filter((node): node is HTMLElement => node instanceof HTMLElement);

    let activeOverlay: HTMLElement | null = null;
    let lastTrigger: HTMLElement | null = null;

    const syncBodyScrollLock = () => {
      const hasOpenOverlay = overlays.some(
        (overlay) => overlay.getAttribute("aria-hidden") === "false",
      );
      if (hasOpenOverlay) {
        document.body.classList.add("project-overlay-open");
      } else {
        document.body.classList.remove("project-overlay-open");
      }
    };

    const closeOverlay = (overlay: HTMLElement, restoreFocus = true) => {
      overlay.classList.add("hidden");
      overlay.setAttribute("aria-hidden", "true");

      if (activeOverlay === overlay) {
        activeOverlay = null;
      }

      syncBodyScrollLock();

      if (restoreFocus && lastTrigger instanceof HTMLElement) {
        lastTrigger.focus();
        lastTrigger = null;
      }
    };

    const openOverlay = (overlay: HTMLElement, trigger: HTMLElement) => {
      if (activeOverlay && activeOverlay !== overlay) {
        closeOverlay(activeOverlay, false);
      }

      overlay.classList.remove("hidden");
      overlay.setAttribute("aria-hidden", "false");
      activeOverlay = overlay;
      lastTrigger = trigger;
      syncBodyScrollLock();

      const closeButton = overlay.querySelector(
        "[data-project-overlay-close-button]",
      );
      if (closeButton instanceof HTMLElement) {
        closeButton.focus();
        return;
      }

      overlay.focus();
    };

    triggers.forEach((trigger) => {
      trigger.addEventListener("click", (event) => {
        const triggerSlug = trigger.getAttribute(
          "data-project-overlay-trigger",
        );
        if (!triggerSlug) return;

        const targetOverlay = overlayBySlug.get(triggerSlug);
        if (!(targetOverlay instanceof HTMLElement)) return;

        event.preventDefault();
        openOverlay(targetOverlay, trigger);
      });
    });

    overlays.forEach((overlay) => {
      const closeControls = overlay.querySelectorAll(
        "[data-project-overlay-close]",
      );
      closeControls.forEach((control) => {
        if (!(control instanceof HTMLElement)) return;

        control.addEventListener("click", (event) => {
          event.preventDefault();
          closeOverlay(overlay);
        });
      });
    });

    document.addEventListener("keydown", (event) => {
      if (event.key !== "Escape") return;
      if (!(activeOverlay instanceof HTMLElement)) return;
      if (activeOverlay.getAttribute("aria-hidden") !== "false") return;

      event.preventDefault();
      closeOverlay(activeOverlay);
    });
  }

  // Module scripts are deferred  DOM is ready when this runs
  initProjectOverlays();
</script>
