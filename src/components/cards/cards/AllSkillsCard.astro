---
/**
 * AllSkillsCard.astro
 * ─────────────────────────────────────────────────────────────────
 * ORGANISM  Contains categories of skills, each with a grid of labels.
 * Flush-right card.
 *
 * Props:
 *   categories  Array of { title, labels[] }
 * ─────────────────────────────────────────────────────────────────
 */
import BaseCard from "../base/BaseCard.astro";
import Label from '../atoms/Label.astro';

interface SkillCategory {
  title: string;
  labels: string[];
}

interface Props {
  categories?: SkillCategory[];
}

const { categories = [] } = Astro.props;
---

<BaseCard
  align="right"
  class="overflow-hidden"
  ariaLabel="All Skills card"
>
  <div class="w-full p-8 md:pl-12 md:pr-32 md:py-12 flex flex-col gap-10">
    
    {categories.map((category: any) => (
      <div class="flex flex-col gap-4">
        <!-- Category Title -->
        <h3 class="font-body font-medium text-lg text-black leading-snug">
          {category.title}
        </h3>
        
        <!-- Category Labels Grid -->
        <div class="flex flex-row flex-wrap gap-2">
          {category.labels && category.labels.map((labelText: string) => (
            <Label label={labelText} />
          ))}
        </div>
      </div>
    ))}

  </div>
</BaseCard>
