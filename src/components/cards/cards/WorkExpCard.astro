---
/**
 * WorkExpCard.astro
 * ─────────────────────────────────────────────────────────────────
 * ORGANISM — Contains rows of work experience content.
 *
 * Props:
 *   experiences — Array of { title, company, date, description, labels }
 * ─────────────────────────────────────────────────────────────────
 */
import BaseCard from "../base/BaseCard.astro";
import Label from '../atoms/Label.astro';

interface Experience {
  title: string;
  company: string;
  date: string;
  description: string;
  labels: string[];
}

interface Props {
  experiences?: Experience[];
}

const { experiences = [] } = Astro.props;
---

<BaseCard
  class="max-w-[1100px] w-full min-h-[278px] overflow-hidden"
  ariaLabel="Work experience card"
>
  <div class="w-full p-8 md:pl-32 md:pr-20 md:py-12 flex flex-col gap-12">
    
    {experiences.map((exp: any) => (
      <div class="flex flex-col gap-5">
        
        <!-- Job Header Row -->
        <div class="flex flex-col md:flex-row md:items-center justify-between gap-4">
          <!-- Left: Title, Company, Date -->
          <div class="flex flex-col gap-3">
            <h3 class="font-body font-semibold text-xl text-black leading-snug">
              {exp.title}
            </h3>
            <div class="flex items-center gap-6 font-body font-medium text-base text-grey-dark">
              <span>{exp.company}</span>
              <span>{exp.date}</span>
            </div>
          </div>
          
          <!-- Right: Labels -->
          <div class="flex flex-row flex-wrap gap-3">
            {exp.labels && exp.labels.map((label: string) => (
              <Label label={label} />
            ))}
          </div>
        </div>
        
        <!-- Job Description -->
        <p class="font-body font-medium text-base md:text-lg text-black leading-relaxed">
          {exp.description}
        </p>
      </div>
    ))}

  </div>
</BaseCard>
