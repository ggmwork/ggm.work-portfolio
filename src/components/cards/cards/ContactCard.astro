---
/**
 * ContactCard.astro
 * ─────────────────────────────────────────────────────────────────
 * ORGANISM  Contact card section.
 * Flush-right card with text and two action buttons.
 *
 * Props:
 *   text       Main body text
 *   btn1Label  First button label
 *   btn2Label  Second button label
 *   btn1Href   Optional href for first button
 *   btn2Href   Optional href for second button
 * ─────────────────────────────────────────────────────────────────
 */
import BaseCard from "../base/BaseCard.astro";
import ButtonSecondary from "../atoms/ButtonSecondary.astro";

interface Props {
  text?: string;
  btn1Label?: string;
  btn2Label?: string;
  btn1Href?: string;
  btn2Href?: string;
}

const {
  text = "If you liked my work give me a call or send me a email",
  btn1Label = "Download CV (PDF)",
  btn2Label = "Get in Touch",
  btn1Href,
  btn2Href,
} = Astro.props;
---

<BaseCard
  align="right"
  class="w-full min-h-[278px] overflow-hidden"
  ariaLabel="Contact card"
>
  <!-- Outer container for card positioning -->
  <div
    class="w-full h-full p-6 md:pl-28 md:pr-10 md:py-10 flex flex-col justify-center min-h-[278px]"
  >
    <div class="relative">
      <!-- Frosted white panel behind text -->
      <div
        class="absolute inset-0 rounded-[19px] bg-white/60 backdrop-blur-[20px]"
        aria-hidden="true"
      >
      </div>
      
      <!-- Inner text container -->
      <div class="relative z-10 p-6 md:p-8 flex flex-col justify-center gap-10">
        <!-- Text Area -->
        <p
          class="font-body font-normal text-base md:text-lg text-black leading-relaxed"
        >
          {text}
        </p>

        <!-- Actions Area -->
        <div
          class="flex flex-col sm:flex-row items-center justify-start gap-6 w-full"
        >
          <ButtonSecondary label={btn1Label} href={btn1Href} />
          <ButtonSecondary label={btn2Label} href={btn2Href} />
        </div>
      </div>
    </div>
  </div>
</BaseCard>
