---
/**
 * EduLangCard.astro
 * ─────────────────────────────────────────────────────────────────
 * ORGANISM — Education and Languages card section.
 * Flush-left card with rows of dual information.
 *
 * Props:
 *   rows — Array of { leftTitle, leftSubtitle, leftDate, rightTitle, rightSubtitle }
 * ─────────────────────────────────────────────────────────────────
 */
import BaseCard from "../base/BaseCard.astro";

interface EducationRow {
  leftTitle: string;
  leftSubtitle: string;
  leftDate: string;
  rightTitle: string;
  rightSubtitle: string;
}

interface Props {
  rows?: EducationRow[];
}

const { rows = [] } = Astro.props;
---

<BaseCard
  class="max-w-[1100px] md:w-[63%] min-h-[278px] overflow-hidden"
  ariaLabel="Education and languages card"
>
  <div class="w-full p-8 md:pl-20 md:pr-12 md:py-16 flex flex-col gap-12">
    
    {rows.map((row: any) => (
      <div class="flex flex-col md:flex-row md:items-start justify-start gap-8 md:gap-32">
        
        <!-- Left: Degree Information -->
        <div class="flex flex-col gap-3 flex-1">
          <h3 class="font-body font-medium text-lg text-black leading-snug">
            {row.leftTitle}
          </h3>
          <div class="flex flex-col sm:flex-row sm:items-center gap-2 sm:gap-6 font-body font-medium text-base text-grey-dark">
            <span>{row.leftSubtitle}</span>
            <span>{row.leftDate}</span>
          </div>
        </div>
        
        <!-- Right: Language Information -->
        <div class="flex flex-col gap-3">
          <h3 class="font-body font-medium text-lg text-black leading-snug">
            {row.rightTitle}
          </h3>
          <span class="font-body font-medium text-base text-grey-dark">
            {row.rightSubtitle}
          </span>
        </div>

      </div>
    ))}

  </div>
</BaseCard>
