---
/**
 * EduLangCard.astro
 * ─────────────────────────────────────────────────────────────────
 * ORGANISM  Education and Languages card section.
 * Flush-left card with rows of dual information.
 *
 * Props:
 *   rows  Array of { leftTitle, leftSubtitle, leftDate, rightTitle, rightSubtitle }
 * ─────────────────────────────────────────────────────────────────
 */
import BaseCard from "../base/BaseCard.astro";

interface EducationRow {
  leftTitle: string;
  leftSubtitle: string;
  leftDate: string;
  rightTitle: string;
  rightSubtitle: string;
}

interface Props {
  rows?: EducationRow[];
}

const { rows = [] } = Astro.props;
---

<BaseCard
  class="max-w-[1100px] w-full min-h-[278px] overflow-hidden"
  ariaLabel="Education and languages card"
>
  <!-- Outer container for card positioning -->
  <div class="w-full p-6 md:pl-36 md:pr-10 md:py-10 flex flex-col justify-center min-h-[278px]">
    
    <div class="relative">
      <!-- Frosted white panel behind text -->
      <div
        class="absolute inset-0 rounded-[19px] bg-white/60 backdrop-blur-[20px]"
        aria-hidden="true"
      >
      </div>
      
      <!-- Inner text container -->
      <div class="relative z-10 p-6 md:p-8 flex flex-col gap-10">
        
        {rows.map((row: any) => (
          <div class="flex flex-col md:flex-row md:items-start justify-start gap-8 md:gap-16">
            
            <!-- Left: Degree Information -->
            <div class="flex flex-col gap-3 w-full md:w-[55%]">
              <h3 class="font-body font-medium text-lg text-black leading-snug">
                {row.leftTitle}
              </h3>
              <div class="flex flex-col sm:flex-row sm:items-center gap-2 sm:gap-6 font-body font-light text-base text-grey-dark">
                <span>{row.leftSubtitle}</span>
                <span>{row.leftDate}</span>
              </div>
            </div>
            
            <!-- Right: Language Information -->
            <div class="flex flex-col gap-3 flex-1">
              <h3 class="font-body font-medium text-lg text-black leading-snug">
                {row.rightTitle}
              </h3>
              <span class="font-body font-light text-base text-grey-dark">
                {row.rightSubtitle}
              </span>
            </div>

          </div>
        ))}

      </div>
    </div>
  </div>
</BaseCard>
