---
/**
 * MoreProjectsCard.astro
 * ─────────────────────────────────────────────────────────────────
 * ORGANISM  Contains filter buttons and a filterable grid of project thumbnails.
 *
 * Props:
 *   filters       Array of filter label strings
 *   activeFilter  Index of the currently active filter
 *   projects      Array of { src, alt, caption, category?, projectSlug? }
 *
 * Client-side behaviour:
 *   Listens for "filter-change" events bubbling from FilterButtons.
 *   Shows/hides project items based on their data-category attribute.
 *   "All" shows every item.
 * ─────────────────────────────────────────────────────────────────
 */
import { Image } from "astro:assets";
import { resolveImage } from "../../../lib/resolve-image";
import BaseCard from "../base/BaseCard.astro";
import FilterButtons from "../atoms/FilterButtons.astro";

interface ProjectThumbnail {
  src: string;
  alt: string;
  caption: string;
  category?: string;
  projectSlug?: string;
}

interface Props {
  filters?: string[];
  activeFilter?: number;
  projects?: ProjectThumbnail[];
}

const {
  filters = ["All", "Design", "UX/UI", "3D", "Motion"],
  activeFilter = 0,
  projects = [],
} = Astro.props;
---

<BaseCard
  class="max-w-[1100px] w-full min-h-[278px] overflow-hidden"
  ariaLabel="More projects card"
>
  <div class="w-full h-full p-8 md:py-12 md:px-32 flex flex-col items-center">
    <!-- Top Center: Filter Buttons -->
    <div class="mb-6 md:mb-12">
      <FilterButtons filters={filters} active={activeFilter} />
    </div>

    <!-- Grid of Thumbnails (filterable) -->
    <div
      class="grid grid-cols-1 md:grid-cols-3 gap-x-6 gap-y-10 w-full"
      data-filter-grid
    >
      {
        projects.map((project: ProjectThumbnail, index: number) => {
          const normalizedProjectSlug =
            typeof project.projectSlug === "string"
              ? project.projectSlug.trim()
              : "";
          const overlayId = normalizedProjectSlug
            ? `project-overlay-${normalizedProjectSlug}`
            : undefined;
          const imageAlt = `${project.alt} ${index + 1}`;
          const caption = project.caption;
          const resolved = resolveImage(project.src);
          const category = project.category || "Design";

          return normalizedProjectSlug ? (
            <button
              type="button"
              data-project-overlay-trigger={normalizedProjectSlug}
              data-category={category}
              aria-controls={overlayId}
              aria-haspopup="dialog"
              aria-label={`Open project details for ${caption.trim()}`}
              class="flex flex-col items-center gap-4 w-full rounded-[2rem] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-black/50 transition-all duration-200 ease-out"
            >
              {resolved ? (
                <Image
                  src={resolved}
                  alt={imageAlt}
                  width={300}
                  height={300}
                  class="img-drop-shadow w-full aspect-square rounded-[2rem] object-cover block ring-1 ring-grey"
                  loading="lazy"
                  decoding="async"
                />
              ) : (
                <img
                  src={project.src}
                  alt={imageAlt}
                  width="300"
                  height="300"
                  class="img-drop-shadow w-full aspect-square rounded-[2rem] object-cover block ring-1 ring-grey"
                  loading="lazy"
                  decoding="async"
                />
              )}
              <p class="font-body font-medium text-sm md:text-base text-black text-center">
                {caption}
              </p>
            </button>
          ) : (
            <div
              class="flex flex-col items-center gap-4 w-full transition-all duration-200 ease-out"
              data-category={category}
            >
              {resolved ? (
                <Image
                  src={resolved}
                  alt={imageAlt}
                  width={300}
                  height={300}
                  class="img-drop-shadow w-full aspect-square rounded-[2rem] object-cover block ring-1 ring-grey"
                  loading="lazy"
                  decoding="async"
                />
              ) : (
                <img
                  src={project.src}
                  alt={imageAlt}
                  width="300"
                  height="300"
                  class="img-drop-shadow w-full aspect-square rounded-[2rem] object-cover block ring-1 ring-grey"
                  loading="lazy"
                  decoding="async"
                />
              )}
              <p class="font-body font-medium text-sm md:text-base text-black text-center">
                {caption}
              </p>
            </div>
          );
        })
      }
    </div>
  </div>
</BaseCard>

<script>
  /**
   * MoreProjectsCard — Filter grid items based on FilterButtons selection.
   *
   * Listens for "filter-change" events bubbling from FilterButtons.
   * Shows/hides [data-category] items inside [data-filter-grid].
   * "All" reveals every item.
   */
  document.addEventListener("filter-change", ((e: CustomEvent) => {
    const category = e.detail?.category;
    if (!category) return;

    document.querySelectorAll<HTMLElement>("[data-filter-grid]").forEach((grid) => {
      const items = grid.querySelectorAll<HTMLElement>("[data-category]");

      items.forEach((item) => {
        const itemCategory = item.getAttribute("data-category") || "";
        const shouldShow = category === "All" || itemCategory === category;

        if (shouldShow) {
          item.classList.remove("opacity-0", "pointer-events-none", "hidden");
          item.classList.add("opacity-100");
        } else {
          item.classList.add("opacity-0", "pointer-events-none");
          // Delay hiding to let opacity transition complete
          setTimeout(() => {
            if (item.classList.contains("opacity-0")) {
              item.classList.add("hidden");
            }
          }, 200);
        }
      });
    });
  }) as EventListener);
</script>
