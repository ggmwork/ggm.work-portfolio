---
/**
 * MoreProjectsCard.astro
 * ─────────────────────────────────────────────────────────────────
 * ORGANISM — Contains filter buttons and a grid of project thumbnails.
 *
 * Props:
 *   filters      — Array of filter label strings
 *   activeFilter — Index of the currently active filter
 *   projects     — Array of { src, alt, caption, projectSlug? }
 * ─────────────────────────────────────────────────────────────────
 */
import { Image } from "astro:assets";
import { resolveImage } from "../../../lib/resolve-image";
import BaseCard from "../base/BaseCard.astro";
import FilterButtons from "../atoms/FilterButtons.astro";

interface ProjectThumbnail {
  src: string;
  alt: string;
  caption: string;
  projectSlug?: string;
}

interface Props {
  filters?: string[];
  activeFilter?: number;
  projects?: ProjectThumbnail[];
}

const {
  filters = ["Design", "UX/UI", "3D", "Motion", "Design", "Design"],
  activeFilter = 0,
  projects = [],
} = Astro.props;
---

<BaseCard
  class="max-w-[1100px] w-full min-h-[278px] overflow-hidden"
  ariaLabel="More projects card"
>
  <div class="w-full h-full p-8 md:py-12 md:px-32 flex flex-col items-center">
    <!-- Top Center: Filter Buttons -->
    <div class="mb-6 md:mb-12">
      <FilterButtons filters={filters} active={activeFilter} />
    </div>

    <!-- Grid of Thumbnails -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-x-6 gap-y-10 w-full">
      {
        projects.map((project: ProjectThumbnail, index: number) => {
          const normalizedProjectSlug =
            typeof project.projectSlug === "string"
              ? project.projectSlug.trim()
              : "";
          const overlayId = normalizedProjectSlug
            ? `project-overlay-${normalizedProjectSlug}`
            : undefined;
          const imageAlt = `${project.alt} ${index + 1}`;
          const caption = project.caption;
          const resolved = resolveImage(project.src);

          return normalizedProjectSlug ? (
            <button
              type="button"
              data-project-overlay-trigger={normalizedProjectSlug}
              aria-controls={overlayId}
              aria-haspopup="dialog"
              aria-label={`Open project details for ${caption.trim()}`}
              class="flex flex-col items-center gap-4 w-full rounded-[2rem] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-black/50"
            >
              {resolved ? (
                <Image
                  src={resolved}
                  alt={imageAlt}
                  width={300}
                  height={300}
                  class="img-drop-shadow w-full aspect-square rounded-[2rem] object-cover block ring-1 ring-grey"
                  loading="lazy"
                  decoding="async"
                />
              ) : (
                <img
                  src={project.src}
                  alt={imageAlt}
                  width="300"
                  height="300"
                  class="img-drop-shadow w-full aspect-square rounded-[2rem] object-cover block ring-1 ring-grey"
                  loading="lazy"
                  decoding="async"
                />
              )}
              <p class="font-body font-medium text-sm md:text-base text-black text-center">
                {caption}
              </p>
            </button>
          ) : (
            <div class="flex flex-col items-center gap-4 w-full">
              {resolved ? (
                <Image
                  src={resolved}
                  alt={imageAlt}
                  width={300}
                  height={300}
                  class="img-drop-shadow w-full aspect-square rounded-[2rem] object-cover block ring-1 ring-grey"
                  loading="lazy"
                  decoding="async"
                />
              ) : (
                <img
                  src={project.src}
                  alt={imageAlt}
                  width="300"
                  height="300"
                  class="img-drop-shadow w-full aspect-square rounded-[2rem] object-cover block ring-1 ring-grey"
                  loading="lazy"
                  decoding="async"
                />
              )}
              <p class="font-body font-medium text-sm md:text-base text-black text-center">
                {caption}
              </p>
            </div>
          );
        })
      }
    </div>
  </div>
</BaseCard>
