---
/**
 * AboutImageBlock.astro
 * ─────────────────────────────────────────────────────────────────
 * ORGANISM — Image card sitting on the right side of the canvas (About section).
 * Sized down to 300x300. Flush-right, fit-content width.
 *
 * Props:
 *   src — Image source path
 *   alt — Image alt text
 * ─────────────────────────────────────────────────────────────────
 */
import { Image } from "astro:assets";
import { resolveImage } from "../../../lib/resolve-image";
import BaseCard from "../base/BaseCard.astro";

interface Props {
  src?: string;
  alt?: string;
}

const {
  src = "/images/projects/project-6/storm_shots/storm_shots%20(1).webp",
  alt = "About image block",
} = Astro.props;

const resolvedImage = resolveImage(src);
---

<BaseCard
  align="right"
  class="overflow-hidden shrink-0 !w-fit md:!w-auto !max-w-none"
  ariaLabel="About Image block"
>
  <!-- 
    justify-start: Image pushed left against the rounded corner.
    pr-3: Reduced padding on the right (from pr-6).
    py-4: Vertical padding to frame the 300x300 image.
  -->
  <div class="flex justify-start pl-4 py-4 pr-3">
    {
      resolvedImage ? (
        <Image
          src={resolvedImage}
          alt={alt}
          width={300}
          height={300}
          class="img-drop-shadow w-[300px] h-[300px] rounded-[40px] object-cover block ring-2 ring-grey"
          loading="lazy"
          decoding="async"
        />
      ) : (
        <img
          src={src}
          alt={alt}
          width="300"
          height="300"
          class="img-drop-shadow w-[300px] h-[300px] rounded-[40px] object-cover block ring-2 ring-grey"
          loading="lazy"
          decoding="async"
        />
      )
    }
  </div>
</BaseCard>
