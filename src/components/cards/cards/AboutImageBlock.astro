---
/**
 * AboutImageBlock.astro
 * ─────────────────────────────────────────────────────────────────
 * ORGANISM  Image card sitting on the right side of the canvas (About section).
 * Sized to 600x600. Flush-right, fit-content width.
 *
 * Props:
 *   src  Image source path
 *   alt  Image alt text
 * ─────────────────────────────────────────────────────────────────
 */
import { Image } from "astro:assets";
import { resolveImage } from "../../../lib/resolve-image";
import BaseCard from "../base/BaseCard.astro";

interface Props {
  src?: string;
  alt?: string;
}

const {
  src = "/images/headshot.webp",
  alt = "Portrait of Gonçalo",
} = Astro.props;

const resolvedImage = resolveImage(src);
---

<BaseCard
  align="right"
  class="overflow-hidden shrink-0 w-full max-w-[400px] !max-w-none md:!w-auto"
  ariaLabel="About Image block"
>
  <!-- 
    justify-start: Image pushed left against the rounded corner.
    pr-3: Reduced padding on the right (from pr-6).
    py-4: Vertical padding to frame the 300x300 image.
  -->
  <div class="flex justify-start pr-15">
    {
      resolvedImage ? (
        <Image
          src={resolvedImage}
          alt={alt}
          width={400}
          height={400}
          class="img-drop-shadow w-full h-auto aspect-square md:w-[400px] md:h-[400px] rounded-[40px] object-cover block ring-2 ring-grey"
          loading="lazy"
          decoding="async"
        />
      ) : (
        <img
          src={src}
          alt={alt}
          width="400"
          height="400"
          class="img-drop-shadow w-full h-auto aspect-square md:w-[400px] md:h-[400px] rounded-[40px] object-cover block ring-2 ring-grey"
          loading="lazy"
          decoding="async"
        />
      )
    }
  </div>
</BaseCard>
