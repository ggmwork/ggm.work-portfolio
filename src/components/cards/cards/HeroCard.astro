---
/**
 * HeroCard.astro
 * ─────────────────────────────────────────────────────────────────
 * ORGANISM — Hero / Header section card.
 * Thin wrapper around BaseCard with p-6 content padding.
 *
 * Visual spec (Figma):
 *   Size    → 913 × 274px (max-w / min-h)
 *   Same visual DNA as BaseCard (white, grid, ring, shadow, blur)
 * ─────────────────────────────────────────────────────────────────
 */
import BaseCard from "../base/BaseCard.astro";
---

<BaseCard
  class="max-w-[913px] md:w-[56%] min-h-[274px]"
  ariaLabel="Hero section card"
>
  <div class="h-full p-6">
    <slot />
  </div>
</BaseCard>
