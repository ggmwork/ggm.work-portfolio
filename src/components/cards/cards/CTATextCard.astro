---
/**
 * CTATextCard.astro
 * ─────────────────────────────────────────────────────────────────
 * ORGANISM  CTA Text Card.
 * Left-aligned card containing two paragraphs of descriptive text.
 *
 * Props:
 *   paragraph1  First paragraph text
 *   paragraph2  Second paragraph text
 * ─────────────────────────────────────────────────────────────────
 */
import BaseCard from "../base/BaseCard.astro";

interface Props {
  paragraph1?: string;
  paragraph2?: string;
}

const {
  paragraph1 = "I'm a designer driven by curiosity and intention. I'm naturally drawn to understanding how things work and how they can improved. I'm constantly exploring, learning and refining the way I think and create, always aiming to elevate the quality of what I put into the world.",
  paragraph2 = "I don't approach projects passively. I need to understand the bigger picture. why something exists, what problem it solves, where it fits and what it's meant to achieve. Whether the goal is growth, clarity or simply adding value, I believe every decision should have a reason behind it. I bring focus, critical thinking and a collaborative mindset, questioning ideas when needed to make sure the work is thoughtful, purposeful and meaningful.",
} = Astro.props;
---

<BaseCard
  class="max-w-[1100px] w-full min-h-[278px] overflow-hidden"
  ariaLabel="CTA text card"
>
  <!-- Outer container for card positioning -->
  <div
    class="w-full p-6 md:pl-36 md:pr-10 md:py-10 flex flex-col justify-center min-h-[278px]"
  >
    <div class="relative">
      <!-- Frosted white panel behind text -->
      <div
        class="absolute inset-0 rounded-[19px] bg-white/60 backdrop-blur-[20px]"
        aria-hidden="true"
      >
      </div>
      
      <!-- Inner text container -->
      <div class="relative z-10 p-6 md:p-8 flex flex-col gap-6">
        <p
          class="font-body font-medium text-base md:text-lg text-black leading-relaxed"
        >
          {paragraph1}
        </p>

        <p
          class="font-body font-medium text-base md:text-lg text-black leading-relaxed"
        >
          {paragraph2}
        </p>
      </div>
    </div>
  </div>
</BaseCard>
