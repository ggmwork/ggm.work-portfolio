---
/**
 * ImageBlock.astro
 * ─────────────────────────────────────────────────────────────────
 * ORGANISM — Card with a single square image.
 * Supports both left (image right-aligned) and right (image left-aligned).
 *
 * Props:
 *   src   — Image source path
 *   alt   — Image alt text
 *   align — "left" (default, flush-left) or "right" (flush-right)
 *
 * Arbitrary value justifications:
 *   [500px] Figma frame size
 *   [40px]  Figma image border-radius
 * ─────────────────────────────────────────────────────────────────
 */
import { Image } from "astro:assets";
import { resolveImage } from "../../../lib/resolve-image";
import BaseCard from "../base/BaseCard.astro";

interface Props {
  src?: string;
  alt?: string;
  align?: "left" | "right";
}

const {
  src = "/images/projects/project-six/storm_shots/storm_shots%20(1).webp",
  alt = "Image block",
  align = "left",
} = Astro.props;

const resolvedImage = resolveImage(src);
const isRight = align === "right";

/* Image flush direction: left-aligned card → image right (justify-end, pl-6)
   right-aligned card → image left (justify-start, pr-6) */
const contentClass = isRight
  ? "flex justify-start pr-6"
  : "flex justify-end pl-6";
---

<BaseCard
  align={align}
  class="max-w-[913px] md:w-[56%]"
  ariaLabel={isRight ? "Image block left card" : "Image block card"}
>
  <div class={contentClass}>
    {
      resolvedImage ? (
        <Image
          src={resolvedImage}
          alt={alt}
          width={500}
          height={500}
          class="img-drop-shadow w-[500px] h-[500px] rounded-[40px] object-cover block ring-2 ring-grey"
          loading="lazy"
          decoding="async"
        />
      ) : (
        <img
          src={src}
          alt={alt}
          width="500"
          height="500"
          class="img-drop-shadow w-[500px] h-[500px] rounded-[40px] object-cover block ring-2 ring-grey"
          loading="lazy"
          decoding="async"
        />
      )
    }
  </div>
</BaseCard>
