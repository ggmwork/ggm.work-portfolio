---
/**
 * HeaderImageBlock.astro
 * ─────────────────────────────────────────────────────────────────
 * ORGANISM  Auto-playing image carousel for the Header section.
 * GSAP crossfade, no controls, no indicators, time-based.
 *
 * Built on BaseCard (align="right", full-bleed approach).
 *
 * Props:
 *   images    Array of { src, alt } objects (min 1)
 *   interval  Seconds between slides (default 4)
 *
 * Animation (GSAP):
 *   Crossfade — current image fades out (opacity 1→0) while
 *   next image fades in (opacity 0→1) over 0.8s ease.
 *   Loops infinitely.
 *
 * Arbitrary value justifications:
 *   [600px]  Figma image dimension spec
 *   [2rem] / [2.5rem]  Figma border-radius spec
 * ─────────────────────────────────────────────────────────────────
 */
import { Image } from "astro:assets";
import { resolveImage } from "../../../lib/resolve-image";
import BaseCard from "../base/BaseCard.astro";

interface CarouselImage {
  src: string;
  alt: string;
}

interface Props {
  images?: CarouselImage[];
  interval?: number;
  /* Legacy single-image fallback */
  src?: string;
  alt?: string;
}

const {
  images: imagesProp,
  interval = 4,
  src: legacySrc = "/images/headshot.webp",
  alt: legacyAlt = "Portrait of Gonçalo",
} = Astro.props;

/* Support both new images array and legacy single src/alt */
const images: CarouselImage[] =
  imagesProp && imagesProp.length > 0
    ? imagesProp
    : [{ src: legacySrc, alt: legacyAlt }];

const resolvedImages = images.map((img) => ({
  resolved: resolveImage(img.src),
  src: img.src,
  alt: img.alt,
}));

const isCarousel = resolvedImages.length > 1;
---

<BaseCard
  align="right"
  class="overflow-hidden shrink-0 w-full max-w-[600px] !max-w-none md:!w-auto"
  ariaLabel="Header Image carousel"
>
  <div
    class="relative aspect-square w-full md:w-[600px] md:h-[600px]"
    data-header-carousel
    data-carousel-interval={String(interval)}
  >
    {
      resolvedImages.map((img, i) => (
        <div
          class:list={[
            "absolute inset-0",
            i === 0 ? "opacity-100 z-10" : "opacity-0 z-0",
          ]}
          data-carousel-slide
        >
          {img.resolved ? (
            <Image
              src={img.resolved}
              alt={img.alt}
              width={600}
              height={600}
              class="img-drop-shadow w-full h-full rounded-[2rem] md:rounded-[2.5rem] object-cover block ring-2 ring-grey"
              loading={i === 0 ? "eager" : "lazy"}
              fetchpriority={i === 0 ? "high" : "auto"}
              decoding="async"
            />
          ) : (
            <img
              src={img.src}
              alt={img.alt}
              width="600"
              height="600"
              class="img-drop-shadow w-full h-full rounded-[2rem] md:rounded-[2.5rem] object-cover block ring-2 ring-grey"
              loading={i === 0 ? "eager" : "lazy"}
              fetchpriority={i === 0 ? "high" : "auto"}
              decoding="async"
            />
          )}
        </div>
      ))
    }
  </div>
</BaseCard>

{isCarousel && (
  <script>
    /**
     * HeaderImageBlock — Vanilla JS crossfade carousel.
     *
     * Zero-dependency replacement for GSAP. Uses CSS transitions
     * for the opacity animation (declared via [data-carousel-slide]).
     * Deferred via requestIdleCallback so it never blocks FCP / LCP.
     */
    const initCarousel = () => {
      document.querySelectorAll<HTMLElement>("[data-header-carousel]").forEach((container) => {
        const slides = container.querySelectorAll<HTMLElement>("[data-carousel-slide]");
        if (slides.length < 2) return;

        const interval = Number(container.dataset.carouselInterval) || 4;
        let current = 0;

        setInterval(() => {
          const prev = slides[current];
          const next = (current + 1) % slides.length;
          const nextSlide = slides[next];

          /* Crossfade: CSS transition handles the easing */
          nextSlide.style.opacity = "1";
          nextSlide.style.zIndex = "10";
          prev.style.opacity = "0";
          prev.style.zIndex = "0";

          current = next;
        }, interval * 1000);
      });
    };

    /* Defer carousel init until browser is idle */
    if ("requestIdleCallback" in window) {
      requestIdleCallback(() => initCarousel());
    } else {
      requestAnimationFrame(() => setTimeout(initCarousel, 0));
    }
  </script>
)}

<style>
  /* Crossfade transition for carousel slides — replaces GSAP tweening */
  [data-carousel-slide] {
    transition: opacity 0.8s cubic-bezier(0.4, 0, 0.2, 1);
  }
</style>

