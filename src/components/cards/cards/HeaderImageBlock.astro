---
/**
 * HeaderImageBlock.astro
 * ─────────────────────────────────────────────────────────────────
 * ORGANISM  Headshot image card for the Header section.
 * Duplicated from AboutImageBlock, styled with zero padding
 * following the HighlightedProjCard full-bleed approach.
 * Flush-right, fit-content width.
 *
 * Props:
 *   src  Image source path
 *   alt  Image alt text
 * ─────────────────────────────────────────────────────────────────
 */
import { Image } from "astro:assets";
import { resolveImage } from "../../../lib/resolve-image";
import BaseCard from "../base/BaseCard.astro";

interface Props {
  src?: string;
  alt?: string;
}

const {
  src = "/images/headshot.webp",
  alt = "Portrait of Gonçalo",
} = Astro.props;

const resolvedImage = resolveImage(src);
---

<BaseCard
  align="right"
  class="overflow-hidden shrink-0 w-full max-w-[600px] !max-w-none md:!w-auto"
  ariaLabel="Header Image block"
>
  <!-- 
    No padding wrapper — full-bleed style matching HighlightedProjCard.
    flex + items-center + justify-center keeps the image centered inside BaseCard.
  -->
  <div class="flex items-center justify-center shrink-0">
    {
      resolvedImage ? (
        <Image
          src={resolvedImage}
          alt={alt}
          width={600}
          height={600}
          class="img-drop-shadow w-full h-auto aspect-square md:w-[600px] md:h-[600px] rounded-[2rem] md:rounded-[2.5rem] object-cover block ring-2 ring-grey"
          loading="eager"
          decoding="async"
        />
      ) : (
        <img
          src={src}
          alt={alt}
          width="600"
          height="600"
          class="img-drop-shadow w-full h-auto aspect-square md:w-[600px] md:h-[600px] rounded-[2rem] md:rounded-[2.5rem] object-cover block ring-2 ring-grey"
          loading="eager"
          decoding="async"
        />
      )
    }
  </div>
</BaseCard>
