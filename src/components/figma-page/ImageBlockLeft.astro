---
/**
 * ImageBlockLeft.astro
 * ─────────────────────────────────────────────────────────────────
 * ORGANISM — Mirrored variant of ImageBlock.
 * Image sits on the LEFT; card is rounded on the LEFT, flush-right.
 *
 * Visual spec (Figma):
 *   Card    → rounded-l-[2rem] / md:rounded-l-[2.5rem]  rounded-r-none
 *             (mirror of ImageBlock which rounds on the right)
 *   Image   → 500 × 500px  w-[500px] h-[500px]  — Figma spec
 *             rounded-[40px]  — Figma spec
 *             object-cover
 *  Alignment → image left, flush with card left rounded edge
 *              pr-6 padding on right only (mirror of pl-6 in ImageBlock)
 *   Shadow  → img-drop-shadow (card drop shadow: 10/10/25/2 black@25%)
 *   Stroke  → ring-2 ring-grey on the image
 *
 * Props:
 *   src  — image source path  (default: project-six photo)
 *   alt  — image alt text
 *
 * Arbitrary value justifications:
 *   [500px]      Figma frame size
 *   [40px]       Figma image border-radius
 *   [5px]        Card ring spec
 *   [2rem]/[2.5rem]  Card rounded-left spec (mirror of right)
 * ─────────────────────────────────────────────────────────────────
 */
import { Image } from "astro:assets";
import { resolveImage } from "../../lib/resolve-image";
interface Props {
  src?: string;
  alt?: string;
}

const {
  src = "/images/projects/project-six/storm_shots/storm_shots%20(1).webp",
  alt = "Image block",
} = Astro.props;

const resolvedImage = resolveImage(src);
---

<article
  class="ml-auto bg-white ring-[5px] ring-grey rounded-l-[2rem] md:rounded-l-[2.5rem] rounded-r-none max-w-[913px] w-full md:w-[56%] base-card-shadow base-card-blur base-card-grid relative"
  aria-label="Image block left card"
>
  <!-- Content layer above the inner grid pseudo-element — image flush left, pr-6 only -->
  <div class="relative z-10 flex justify-start pr-6">
    {
      resolvedImage ? (
        <Image
          src={resolvedImage}
          alt={alt}
          width={500}
          height={500}
          class="img-drop-shadow w-[500px] h-[500px] rounded-[40px] object-cover block ring-2 ring-grey"
          loading="lazy"
          decoding="async"
        />
      ) : (
        <img
          src={src}
          alt={alt}
          width="500"
          height="500"
          class="img-drop-shadow w-[500px] h-[500px] rounded-[40px] object-cover block ring-2 ring-grey"
          loading="lazy"
          decoding="async"
        />
      )
    }
  </div>
</article>
