---
/**
 * HighlightedProjCardRight.astro
 * ─────────────────────────────────────────────────────────────────
 * ORGANISM — Highlighted Project Card (Right Variant).
 * Mirrored version of the standard HighlightedProjCard:
 *   - Shell: Sits flush-right on the canvas (rounded-left, flat-right).
 *   - Left: Square image
 *   - Right: TextBlock primary headline + 3 Labels + TextBlock secondary text
 *
 * Visual spec (Figma reference):
 *   Card    → ml-auto (push right), bg-white, base-card-shadow, base-card-blur,
 *             base-card-grid, ring-[5px] ring-grey, rounded-l-[2.5rem], rounded-r-none.
 *             Width md:w-[63%] (matching Header).
 *   Content → Flex row container.
 *     Left  → 240x240 (or 280x280) image, rounded-[40px], img-drop-shadow.
 *     Right → Frosted panel holding a title, a row of 3 labels, and a paragraph.
 * ─────────────────────────────────────────────────────────────────
 */
import { Image } from "astro:assets";
import { resolveImage } from "../../lib/resolve-image";
import Label from "./Label.astro";

interface Props {
  title?: string;
  description?: string;
  imageSrc?: string;
  imageAlt?: string;
  labels?: string[];
  projectSlug?: string;
}

const {
  title = "Rebranding Nexled + UI Components",
  description = "I work across web and digital design, taking direct ownership of UI/UX, e-commerce, and visual execution to deliver cohesive and reliable solutions. My role combines hands-on design with system thinking, structured workflows, and cross-platform consistency.",
  imageSrc = "/images/projects/project-six/storm_shots/storm_shots%20(1).webp",
  imageAlt = "Highlighted Project",
  labels = ["Design", "Design", "Design"],
  projectSlug,
} = Astro.props;

const normalizedProjectSlug =
  typeof projectSlug === "string" ? projectSlug.trim() : "";
const overlayId = normalizedProjectSlug
  ? `project-overlay-${normalizedProjectSlug}`
  : undefined;
const resolvedImage = resolveImage(imageSrc);
---

<article
  class="ml-auto bg-white ring-[5px] ring-grey rounded-l-[2rem] md:rounded-l-[2.5rem] rounded-r-none max-w-[1100px] w-full md:w-[63%] min-h-[278px] base-card-shadow base-card-blur base-card-grid relative overflow-hidden flex flex-col md:flex-row items-stretch justify-between"
  aria-label="Highlighted project card (right mirrored)"
>
  <!-- 
    Left Side: Image
    Moved to the left side per the Right Variant spec.
  -->
  <div
    class="relative z-10 w-full md:w-auto p-6 flex items-center justify-center shrink-0"
  >
    {
      overlayId ? (
        <button
          type="button"
          data-project-overlay-trigger={normalizedProjectSlug}
          aria-controls={overlayId}
          aria-haspopup="dialog"
          aria-label={`Open project details for ${title}`}
          class="rounded-[40px] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-black/50"
        >
          {resolvedImage ? (
            <Image
              src={resolvedImage}
              alt={imageAlt}
              width={240}
              height={240}
              class="img-drop-shadow w-[240px] h-[240px] md:w-[280px] md:h-[280px] rounded-[40px] object-cover block ring-2 ring-grey"
              loading="lazy"
              decoding="async"
            />
          ) : (
            <img
              src={imageSrc}
              alt={imageAlt}
              width="240"
              height="240"
              class="img-drop-shadow w-[240px] h-[240px] md:w-[280px] md:h-[280px] rounded-[40px] object-cover block ring-2 ring-grey"
              loading="lazy"
              decoding="async"
            />
          )}
        </button>
      ) : resolvedImage ? (
        <Image
          src={resolvedImage}
          alt={imageAlt}
          width={240}
          height={240}
          class="img-drop-shadow w-[240px] h-[240px] md:w-[280px] md:h-[280px] rounded-[40px] object-cover block ring-2 ring-grey"
          loading="lazy"
          decoding="async"
        />
      ) : (
        <img
          src={imageSrc}
          alt={imageAlt}
          width="240"
          height="240"
          class="img-drop-shadow w-[240px] h-[240px] md:w-[280px] md:h-[280px] rounded-[40px] object-cover block ring-2 ring-grey"
          loading="lazy"
          decoding="async"
        />
      )
    }
  </div>

  <!-- 
    Right Side: Text & Labels
    Frosted panel wrapper. Padding adjusted to frame the right side cleanly.
  -->
  <div
    class="relative z-10 flex-1 p-6 md:pr-15 md:pl-10 md:py-8 flex flex-col justify-center"
  >
    <div class="relative">
      <div
        class="absolute inset-0 rounded-[19px] bg-white/60 backdrop-blur-[20px]"
        aria-hidden="true"
      >
      </div>
      <div class="relative z-10 px-5 py-4 flex flex-col gap-4">
        <!-- Title -->
        <h3 class="font-body font-medium text-lg text-black leading-snug">
          {title}
        </h3>

        <!-- Labels Row -->
        <div class="flex flex-row flex-wrap gap-2">
          {labels.map((label: string) => <Label label={label} />)}
        </div>

        <!-- Description -->
        <p
          class="font-body font-medium text-base md:text-lg text-black leading-relaxed"
        >
          {description}
        </p>
      </div>
    </div>
  </div>
</article>
