---
/**
 * HighlightedProjCard.astro
 * ─────────────────────────────────────────────────────────────────
 * ORGANISM — Highlighted Project Card.
 * Supports both left (image right) and right (image left) alignment.
 *
 * Props:
 *   title       — Project title
 *   description — Project description paragraph
 *   imageSrc    — Project image path
 *   imageAlt    — Project image alt text
 *   labels      — Array of label strings
 *   projectSlug — Slug for overlay trigger (optional)
 *   align       — "left" (default, image right) or "right" (image left)
 *   alignRight  — Legacy alias for align="right" (from markdown pipeline)
 *
 * Arbitrary value justifications:
 *   [40px]  Figma image border-radius
 *   [19px]  Frosted panel border-radius (Figma spec)
 *   [20px]  Frosted panel backdrop blur (Figma spec)
 * ─────────────────────────────────────────────────────────────────
 */
import { Image } from "astro:assets";
import { resolveImage } from "../../lib/resolve-image";
import BaseCard from "./BaseCard.astro";
import Label from "./Label.astro";

interface Props {
  title?: string;
  description?: string;
  imageSrc?: string;
  imageAlt?: string;
  labels?: string[];
  projectSlug?: string;
  align?: "left" | "right";
  alignRight?: boolean;
}

const {
  title = "Rebranding Nexled + UI Components",
  description = "I work across web and digital design, taking direct ownership of UI/UX, e-commerce, and visual execution to deliver cohesive and reliable solutions. My role combines hands-on design with system thinking, structured workflows, and cross-platform consistency.",
  imageSrc = "/images/projects/project-six/storm_shots/storm_shots%20(1).webp",
  imageAlt = "Highlighted Project",
  labels = ["Design", "Design", "Design"],
  projectSlug,
  align: alignProp,
  alignRight,
} = Astro.props;

/* Resolve align: explicit align prop wins, then alignRight boolean, then default "left" */
const align: "left" | "right" = alignProp ?? (alignRight ? "right" : "left");
const isRight = align === "right";

const resolvedImage = resolveImage(imageSrc);

const normalizedProjectSlug =
  typeof projectSlug === "string" ? projectSlug.trim() : "";
const overlayId = normalizedProjectSlug
  ? `project-overlay-${normalizedProjectSlug}`
  : undefined;

/* Padding direction flips with alignment */
const textPanelPadding = isRight
  ? "p-6 md:pr-15 md:pl-10 md:py-8"
  : "p-6 md:pl-15 md:pr-10 md:py-8";
---

<BaseCard
  align={align}
  class="max-w-[1100px] md:w-[63%] min-h-[278px] overflow-hidden flex flex-col md:flex-row items-stretch justify-between"
  ariaLabel={isRight
    ? "Highlighted project card (right mirrored)"
    : "Highlighted project card"}
>
  {/* ── Image Panel ── */}
  {
    isRight && (
      <div class="w-full md:w-auto p-6 flex items-center justify-center shrink-0">
        {overlayId ? (
          <button
            type="button"
            data-project-overlay-trigger={normalizedProjectSlug}
            aria-controls={overlayId}
            aria-haspopup="dialog"
            aria-label={`Open project details for ${title}`}
            class="rounded-[40px] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-black/50"
          >
            {resolvedImage ? (
              <Image
                src={resolvedImage}
                alt={imageAlt}
                width={240}
                height={240}
                class="img-drop-shadow w-60 h-60 md:w-70 md:h-70 rounded-[40px] object-cover block ring-2 ring-grey"
                loading="lazy"
                decoding="async"
              />
            ) : (
              <img
                src={imageSrc}
                alt={imageAlt}
                width="240"
                height="240"
                class="img-drop-shadow w-60 h-60 md:w-70 md:h-70 rounded-[40px] object-cover block ring-2 ring-grey"
                loading="lazy"
                decoding="async"
              />
            )}
          </button>
        ) : resolvedImage ? (
          <Image
            src={resolvedImage}
            alt={imageAlt}
            width={240}
            height={240}
            class="img-drop-shadow w-60 h-60 md:w-70 md:h-70 rounded-[40px] object-cover block ring-2 ring-grey"
            loading="lazy"
            decoding="async"
          />
        ) : (
          <img
            src={imageSrc}
            alt={imageAlt}
            width="240"
            height="240"
            class="img-drop-shadow w-60 h-60 md:w-70 md:h-70 rounded-[40px] object-cover block ring-2 ring-grey"
            loading="lazy"
            decoding="async"
          />
        )}
      </div>
    )
  }

  {/* ── Text & Labels Panel ── */}
  <div class:list={["flex-1 flex flex-col justify-center", textPanelPadding]}>
    <div class="relative">
      <div
        class="absolute inset-0 rounded-[19px] bg-white/60 backdrop-blur-[20px]"
        aria-hidden="true"
      >
      </div>
      <div class="relative z-10 px-5 py-4 flex flex-col gap-4">
        <!-- Title -->
        <h3 class="font-body font-medium text-lg text-black leading-snug">
          {title}
        </h3>

        <!-- Labels Row -->
        <div class="flex flex-row flex-wrap gap-2">
          {labels.map((label: string) => <Label label={label} />)}
        </div>

        <!-- Description -->
        <p
          class="font-body font-medium text-base md:text-lg text-black leading-relaxed"
        >
          {description}
        </p>
      </div>
    </div>
  </div>

  {/* ── Image Panel (left-aligned variant: image on right) ── */}
  {
    !isRight && (
      <div class="w-full md:w-auto p-6 flex items-center justify-center shrink-0">
        {overlayId ? (
          <button
            type="button"
            data-project-overlay-trigger={normalizedProjectSlug}
            aria-controls={overlayId}
            aria-haspopup="dialog"
            aria-label={`Open project details for ${title}`}
            class="rounded-[40px] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-black/50"
          >
            {resolvedImage ? (
              <Image
                src={resolvedImage}
                alt={imageAlt}
                width={240}
                height={240}
                class="img-drop-shadow w-60 h-60 md:w-70 md:h-70 rounded-[40px] object-cover block ring-2 ring-grey"
                loading="lazy"
                decoding="async"
              />
            ) : (
              <img
                src={imageSrc}
                alt={imageAlt}
                width="240"
                height="240"
                class="img-drop-shadow w-60 h-60 md:w-70 md:h-70 rounded-[40px] object-cover block ring-2 ring-grey"
                loading="lazy"
                decoding="async"
              />
            )}
          </button>
        ) : resolvedImage ? (
          <Image
            src={resolvedImage}
            alt={imageAlt}
            width={240}
            height={240}
            class="img-drop-shadow w-60 h-60 md:w-70 md:h-70 rounded-[40px] object-cover block ring-2 ring-grey"
            loading="lazy"
            decoding="async"
          />
        ) : (
          <img
            src={imageSrc}
            alt={imageAlt}
            width="240"
            height="240"
            class="img-drop-shadow w-60 h-60 md:w-70 md:h-70 rounded-[40px] object-cover block ring-2 ring-grey"
            loading="lazy"
            decoding="async"
          />
        )}
      </div>
    )
  }
</BaseCard>
