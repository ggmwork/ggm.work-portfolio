---
/**
 * HighlightedProjCard.astro
 * ─────────────────────────────────────────────────────────────────
 * ORGANISM — Highlighted Project Card.
 * Duplicates the HeaderCard shell but replaces the contents:
 *   - Left: TextBlock primary headline + 3 Labels + TextBlock secondary text
 *   - Right: Square image
 *
 * Visual spec (Figma reference):
 *   Card    → bg-white, base-card-shadow, base-card-blur, base-card-grid,
 *             ring-[5px] ring-grey, rounded-r-[2rem], rounded-l-none.
 *             Width md:w-[63%] (matching Header).
 *   Content → Flex row container.
 *     Left  → Frosted panel holding a title, a row of 3 labels, and a paragraph.
 *     Right → 280x280 (or similar) image, rounded-[40px], img-drop-shadow.
 * ─────────────────────────────────────────────────────────────────
 */
import Label from './Label.astro';

interface Props {
  title?: string;
  description?: string;
  imageSrc?: string;
  imageAlt?: string;
  labels?: string[];
  projectSlug?: string;
}

const {
  title = 'Rebranding Nexled + UI Components',
  description = 'I work across web and digital design, taking direct ownership of UI/UX, e-commerce, and visual execution to deliver cohesive and reliable solutions. My role combines hands-on design with system thinking, structured workflows, and cross-platform consistency.',
  imageSrc = '/images/projects/project-six/storm_shots/storm_shots%20(1).webp',
  imageAlt = 'Highlighted Project',
  labels = ['Design', 'Design', 'Design'],
  projectSlug,
} = Astro.props;
---

<article
  class="bg-white ring-[5px] ring-grey rounded-r-[2rem] md:rounded-r-[2.5rem] rounded-l-none max-w-[1100px] w-full md:w-[63%] min-h-[278px] base-card-shadow base-card-blur base-card-grid relative overflow-hidden flex flex-col md:flex-row items-stretch justify-between"
  aria-label="Highlighted project card"
>
  <!-- 
    Left Side: Text & Labels
    Frosted panel wrapper similar to TextBlock matching the reference visual.
  -->
  <div class="relative z-10 flex-1 p-6 md:pl-15 md:pr-10 md:py-8 flex flex-col justify-center">
    <div class="relative">
      <div
        class="absolute inset-0 rounded-[19px] bg-white/85 blur-[20px]"
        aria-hidden="true"
      ></div>
      <div class="relative z-10 px-5 py-4 flex flex-col gap-4">
        <!-- Title -->
        <h3 class="font-body font-medium text-lg text-black leading-snug">
          {title}
        </h3>
        
        <!-- Labels Row -->
        <div class="flex flex-row flex-wrap gap-2">
          {labels.map((label: string) => (
            <Label label={label} />
          ))}
        </div>
        
        <!-- Description -->
        <p class="font-body font-medium text-base md:text-lg text-black leading-relaxed">
          {description}
        </p>
      </div>
    </div>
  </div>

  <!-- 
  Right Side: Image
  Matches the prompt requested "just image not the card"
  -->
  <div class="relative z-10 w-full md:w-auto p-6 flex items-center justify-center shrink-0">
    {projectSlug ? (
      <button
        type="button"
        data-project-overlay-trigger={projectSlug}
        aria-controls="project-overlay"
        aria-haspopup="dialog"
        aria-label={`Open project details for ${title}`}
        class="rounded-[40px] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-black/50"
      >
        <img
          src={imageSrc}
          alt={imageAlt}
          width="240"
          height="240"
          class="img-drop-shadow w-[240px] h-[240px] md:w-[280px] md:h-[280px] rounded-[40px] object-cover block ring-2 ring-grey"
          loading="lazy"
          decoding="async"
        />
      </button>
    ) : (
      <img
        src={imageSrc}
        alt={imageAlt}
        width="240"
        height="240"
        class="img-drop-shadow w-[240px] h-[240px] md:w-[280px] md:h-[280px] rounded-[40px] object-cover block ring-2 ring-grey"
        loading="lazy"
        decoding="async"
      />
    )}
  </div>
</article>
