---
/**
 * HeaderCard.astro
 * ─────────────────────────────────────────────────────────────────
 * ORGANISM — Header section card.
 * Duplicates the HeroCard shell — same card language (white, grid,
 * ring-[5px] grey, rounded-right, flush-left).
 *
 * Visual spec (Figma reference):
 *   Card    → same as HeroCard (bg-white, base-card-shadow, base-card-blur,
 *              base-card-grid, ring-[5px] ring-grey, rounded-r, flush-left)
 *   Content → flex-col, justify-between, full height
 *     Top   → TextBlock (primary headline + secondary sub-line)
 *     Bot   → Button row: 2 × ButtonSecondary  +  1 × ButtonPrimary
 *
 * Props:
 *   primary    — TextBlock primary line
 *   secondary  — TextBlock secondary line
 *   btn1Label  — First secondary button label
 *   btn2Label  — Second secondary button label
 *   btn3Label  — Primary button label
 *   btn1Href   — Optional href for first secondary button
 *   btn2Href   — Optional href for second secondary button
 *   btn3Href   — Optional href for primary button
 *
 * Arbitrary value justifications:
 *   [913px]  Figma frame width (inherited from HeroCard)
 *   [274px]  Figma frame height (inherited from HeroCard)
 *   [2rem]/[2.5rem]  Card rounded-right (inherited from card language)
 *   [5px]    Card ring spec (inherited from card language)
 * ─────────────────────────────────────────────────────────────────
 */
interface Props {
  primary?: string;
  secondary?: string;
  btn1Label?: string;
  btn2Label?: string;
  btn3Label?: string;
  btn1Href?: string;
  btn2Href?: string;
  btn3Href?: string;
}

import TextBlock from './TextBlock.astro';
import ButtonSecondary from './ButtonSecondary.astro';
import ButtonPrimary from './ButtonPrimary.astro';

const {
  primary   = 'Designer merging visual creativity and problem solving into impactful digital solutions.',
  secondary = 'Based in Porto, Portugal · Currently open to new roles',
  btn1Label = 'Download CV (PDF)',
  btn2Label = 'Get in Touch',
  btn3Label = 'Explore My Work',
  btn1Href,
  btn2Href,
  btn3Href,
} = Astro.props;
---

<!--
  Card shell — same spec as HeroCard.
  flush-left: rounded-l-none, no left margin.
-->
<article
  class="bg-white ring-[5px] ring-grey rounded-r-[2rem] md:rounded-r-[2.5rem] rounded-l-none max-w-[1100px] w-full md:w-[63%] min-h-[278px] base-card-shadow base-card-blur base-card-grid relative"
  aria-label="Header card"
>
  <!-- Content layer above the inner grid pseudo-element -->
  <div class="relative z-10 pt-6 pr-6 pb-6 pl-15 flex flex-col justify-start gap-6">

    <!-- TOP: TextBlock — primary headline + secondary sub-line -->
    <TextBlock primary={primary} secondary={secondary} />

    <!-- BOTTOM: Button row — 2 × secondary, 1 × primary -->
    <div class="flex flex-row flex-wrap gap-[55px] pl-20 pr-10">
      <ButtonSecondary label={btn1Label} href={btn1Href} />
      <ButtonSecondary label={btn2Label} href={btn2Href} />
      <ButtonPrimary   label={btn3Label} href={btn3Href} />
    </div>

  </div>
</article>
