---
/**
 * AllSkillsCard.astro
 * ─────────────────────────────────────────────────────────────────
 * ORGANISM — Contains categories of skills, each with a grid of labels.
 * Designed to sit flush on the right side of the canvas (like HighlightedProjCardRight).
 *
 * Visual spec (Figma reference):
 *   Card    → bg-white, base-card-shadow, base-card-blur, base-card-grid,
 *             ring-[5px] ring-grey, rounded-l-[2rem] md:rounded-l-[2.5rem], rounded-r-none.
 *             Width matches the available flex space or an explicit percentage.
 *   Content → Flex col container holding categories.
 *     Item  → A category title string above a flexible grid of labels.
 * ─────────────────────────────────────────────────────────────────
 */
import Label from './Label.astro';

interface SkillCategory {
  title: string;
  labels: string[];
}

interface Props {
  categories?: SkillCategory[];
}

const { categories = [] } = Astro.props;
---

<article
  class="ml-auto bg-white ring-[5px] ring-grey rounded-l-[2rem] md:rounded-l-[2.5rem] rounded-r-none w-full base-card-shadow base-card-blur base-card-grid relative overflow-hidden"
  aria-label="All Skills card"
>
  <!-- Content wrapper inside the card grid -->
  <div class="relative z-10 w-full p-8 md:px-12 md:py-12 flex flex-col gap-10">
    
    {categories.map((category: any) => (
      <div class="flex flex-col gap-4">
        <!-- Category Title -->
        <h3 class="font-body font-medium text-lg text-black leading-snug">
          {category.title}
        </h3>
        
        <!-- Category Labels Grid -->
        <div class="flex flex-row flex-wrap gap-2">
          {category.labels && category.labels.map((labelText: string) => (
            <Label label={labelText} />
          ))}
        </div>
      </div>
    ))}

  </div>
</article>
