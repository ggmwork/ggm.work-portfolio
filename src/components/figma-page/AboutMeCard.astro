---
/**
 * AboutMeCard.astro
 * ─────────────────────────────────────────────────────────────────
 * ORGANISM — About Me section card.
 *
 * Visual spec (Figma reference):
 *   Card    → bg-white, base-card-shadow, base-card-blur, base-card-grid,
 *             ring-[5px] ring-grey, rounded-r-[2.5rem], rounded-l-none.
 *             Matches HeaderCard width (md:w-[63%], max-w-[1100px]).
 *   Content → Flex layout (row on desktop, col on mobile).
 *     Left  → TextBlockVariant2 content (two paragraphs) sitting cleanly on the card.
 *     Right → Profile Image (square, rounded-40px, img-drop-shadow, ring-2 ring-grey).
 *
 * Props:
 *   paragraph1  — First text paragraph
 *   paragraph2  — Second text paragraph
 *   imageSrc    — Profile image path
 *   imageAlt    — Profile image alt text
 * ─────────────────────────────────────────────────────────────────
 */
interface Props {
  paragraph1?: string;
  paragraph2?: string;
  imageSrc?: string;
  imageAlt?: string;
}

const {
  paragraph1 = 'I’m a designer driven by curiosity and intention. I’m naturally drawn to understanding how things work and how they can improved. I’m constantly exploring, learning and refining the way I think and create, always aiming to elevate the quality of what I put into the world.',
  paragraph2 = 'I don’t approach projects passively. I need to understand the bigger picture. why something exists, what problem it solves, where it fits and what it’s meant to achieve. Whether the goal is growth, clarity or simply adding value, I believe every decision should have a reason behind it. I bring focus, critical thinking and a collaborative mindset, questioning ideas when needed to make sure the work is thoughtful, purposeful and meaningful.',
  imageSrc = '/images/projects/project-six/storm_shots/storm_shots%20(1).webp', // Using a placeholder that exists in the current repo, user will swap later
  imageAlt = 'Gonçalo Mendonça Profile Picture',
} = Astro.props;
---

<article
  class="bg-white ring-[5px] ring-grey rounded-r-[2rem] md:rounded-r-[2.5rem] rounded-l-none max-w-[1100px] w-full md:w-[63%] min-h-[350px] base-card-shadow base-card-blur base-card-grid relative overflow-hidden flex flex-col justify-center"
  aria-label="About Me card"
>
  <!-- 
    Left Side: Text Content 
    Uses the exact paragraph styling from TextBlockVariant2.
    Padding aligned with the HeaderCard (pl-15, pt-10, pb-10, pr-6)
  -->
  <div class="relative z-10 p-6 md:pl-15 md:py-10 md:pr-10 flex-1 flex flex-col gap-5">
    <div class="relative">
      <!-- Frosted white panel behind text to ensure readability against the grid -->
      <div
        class="absolute inset-0 rounded-[19px] bg-white/85 blur-[20px]"
        aria-hidden="true"
      ></div>
      <div class="relative z-10 px-5 py-4 flex flex-col gap-4">
        <p class="font-body font-medium text-lg text-black leading-relaxed">
          {paragraph1}
        </p>
        <p class="font-body font-medium text-lg text-black leading-relaxed">
          {paragraph2}
        </p>
      </div>
    </div>
  </div>
</article>
