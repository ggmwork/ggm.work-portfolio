---
/**
 * MoreProjectsCard.astro
 * ─────────────────────────────────────────────────────────────────
 * ORGANISM — Contains filter buttons and a grid of project thumbnails.
 * Duplicates the HeaderCard shell per user request.
 *
 * Visual spec (Figma reference):
 *   Card    → bg-white, base-card-shadow, base-card-blur, base-card-grid,
 *             ring-[5px] ring-grey, rounded-r-[2rem] md:rounded-r-[2.5rem], rounded-l-none.
 *             Width max-w-[1100px] w-full md:w-[63%] (matching Header).
 *   Content → Flex col container.
 *     Top   → FilterButtons block, centered horizontally.
 *     Grid  → 3 columns x 2 rows (md:grid-cols-3). 
 *     Item  → Square rounded image + descriptive text below it.
 * ─────────────────────────────────────────────────────────────────
 */
import FilterButtons from './FilterButtons.astro';

interface ProjectThumbnail {
  src: string;
  alt: string;
  caption: string;
}

interface Props {
  filters?: string[];
  activeFilter?: number;
  projects?: ProjectThumbnail[];
}

const { 
  filters = ["Design", "UX/UI", "3D", "Motion", "Design", "Design"],
  activeFilter = 0,
  projects = [] 
} = Astro.props;
---

<article
  class="bg-white ring-[5px] ring-grey rounded-r-[2rem] md:rounded-r-[2.5rem] rounded-l-none max-w-[1100px] w-full md:w-[63%] min-h-[278px] base-card-shadow base-card-blur base-card-grid relative overflow-hidden"
  aria-label="More projects card"
>
  <div class="relative z-10 w-full h-full p-8 md:p-12 flex flex-col items-center">
    
    <!-- Top Center: Filter Buttons -->
    <div class="mb-12">
      <FilterButtons filters={filters} active={activeFilter} />
    </div>

    <!-- Grid of Thumbnails -->
    <!-- 
      gap-x-8 spaces the columns horizontally 
      gap-y-12 spaces the rows vertically
    -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-x-6 gap-y-10 w-full">
      {projects.map((project: any, index: number) => (
        <div class="flex flex-col items-center gap-4">
          <!-- Image -->
          <img
            src={project.src}
            alt={`${project.alt} ${index + 1}`}
            class="img-drop-shadow w-full aspect-square rounded-[2rem] object-cover block ring-1 ring-grey"
            loading="lazy"
            decoding="async"
          />
          <!-- Caption -->
          <p class="font-body font-medium text-sm md:text-base text-black text-center">
            {project.caption}
          </p>
        </div>
      ))}
    </div>

  </div>
</article>
