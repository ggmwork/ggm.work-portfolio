---
/**
 * ContactCard.astro
 * ─────────────────────────────────────────────────────────────────
 * ORGANISM — Contact card section.
 * Designed to sit flush on the right side of the canvas (like AllSkillsCard).
 *
 * Visual spec (Figma reference):
 *   Card    → bg-white, base-card-shadow, base-card-blur, base-card-grid,
 *             ring-[5px] ring-grey, rounded-l-[2rem] md:rounded-l-[2.5rem], rounded-r-none.
 *             Width max-w-[1100px] w-full md:w-[63%] (matching Header).
 *   Content → Flex col container holding text and two buttons aligned to the right.
 *
 * Props:
 *   text      — Main body text
 *   btn1Label — First button label
 *   btn2Label — Second button label
 *   btn1Href  — Optional href for first button
 *   btn2Href  — Optional href for second button
 * ─────────────────────────────────────────────────────────────────
 */
import ButtonSecondary from './ButtonSecondary.astro';

interface Props {
  text?: string;
  btn1Label?: string;
  btn2Label?: string;
  btn1Href?: string;
  btn2Href?: string;
}

const {
  text = 'If you liked my work give me a call or send me a email',
  btn1Label = 'Download CV (PDF)',
  btn2Label = 'Get in Touch',
  btn1Href,
  btn2Href,
} = Astro.props;
---

<article
  class="ml-auto bg-white ring-[5px] ring-grey rounded-l-[2rem] md:rounded-l-[2.5rem] rounded-r-none w-full md:w-[63%] min-h-[278px] base-card-shadow base-card-blur base-card-grid relative overflow-hidden"
  aria-label="Contact card"
>
  <!-- Content wrapper inside the card grid -->
  <!-- Note: PR-12 to push button boundaries in, matching visual -->
  <div class="relative z-10 w-full h-full p-8 md:pl-20 md:pr-24 md:py-16 flex flex-col justify-center gap-10 min-h-[278px]">
    
    <!-- Text Area -->
    <p class="font-body font-medium text-lg text-black leading-relaxed">
      {text}
    </p>

    <!-- Actions Area (Aligned right side of the inner container) -->
    <div class="flex flex-col sm:flex-row items-center justify-end gap-6 w-full">
      <ButtonSecondary label={btn1Label} href={btn1Href} />
      <ButtonSecondary label={btn2Label} href={btn2Href} />
    </div>

  </div>
</article>

